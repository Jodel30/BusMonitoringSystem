@{
    // THIS LINE TELLS THE PAGE WHICH NAVBAR TO USE
    Layout = "~/Views/Shared/SchoolLayout.cshtml";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>STMS | LGU Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true">
    <style>

    </style>
</head>
<body>



    <div class="main-wrapper">

        <!-- SECTION: DASHBOARD HOME -->
        <section class="main-content" id="dashboard">
            <div class="hero-banner">
                <div class="hero-text">
                    <h1>Student Transport<br>Monitoring System</h1>

                </div>
                <div class="hero-visual">
                    <img src="~/freebus.jpg" alt="Bus Image">
                </div>
            </div>

            <div class="stats-grid">
                <div class="stat-card">
                    <div class="icon-box blue"><i class="fa-solid fa-users"></i></div>
                    <div class="info"><h3>Students</h3><p>0</p></div>
                    <img src="~/students-removebg-preview.png" class="bg-icon">
                </div>
            </div>
        </section>

        <!-- SECTION: STUDENTS -->
        @model List<MonitoringSystem.Models.Student>

        <section class="main-content" id="students">
            <!-- BANNER -->
            <div class="report-banner">
                <div class="report-text"><h1>Students</h1></div>
            </div>

            <!-- STAT CARD -->
            <div class="analytics-summary">
                <div class="insight-card">
                    <div class="icon-box blue"><i class="fa-solid fa-users"></i></div>
                    <div class="insight-data">
                        <span class="label">Total Registered Students</span>
                        <p>@Model.Count</p>
                    </div>
                    <img src="~/students-removebg-preview.png">
                </div>
            </div>

            <!-- REGISTRATION TRIGGER -->
            <div class="report-filters glass-card">
                <div class="filter-controls"><h1>Register New Student</h1></div>
                <button class="btn-generate" onclick="openModal()">
                    <i class="fa-solid fa-user-plus"></i> Add new Student
                </button>
            </div>

            <!-- 1. REGISTRATION MODAL -->
            <div class="modal-overlay" id="modalOverlay" onclick="closeModalOutside(event)">
                <div class="modal-content glass-card registration-section" onclick="event.stopPropagation()">
                    <button class="btn-close-modal" onclick="closeModal()">&times;</button>
                    <div class="card-header-gradient">
                        <i class="fa-solid fa-user-plus"></i>
                            <h2>New Student Registration</h2>
                            <p>Fill in details to generate profile and QR identity.</p>
                        
                    </div>

                    <form asp-action="RegisterStudent" asp-controller="SchoolDashboard" method="post" enctype="multipart/form-data" class="modern-form">
                        <div class="form-grid">
                            <div class="form-group full-width">
                                <label> LRN *</label>
                                <input type="text" name="LRN" placeholder="12-digit LRN" required>
                            </div>
                            <div class="form-group">
                                <label>Student Id</label>
                                <input type="text" name="StudentId" placeholder="Internal ID">
                            </div>
                            <div class="form-group">
                                <label>First Name *</label>
                                <input type="text" name="FirstName" placeholder="First Name" required>
                            </div>
                            <div class="form-group">
                                <label>Middle Name</label>
                                <input type="text" name="MiddleName" placeholder="Middle Name">
                            </div>
                            <div class="form-group">
                                <label>Last Name *</label>
                                <input type="text" name="LastName" placeholder="Last Name" required>
                            </div>
                            <div class="form-group">
                                <label>Grade Level *</label>
                                <select name="GradeLevel" required>
                                    <option value="" disabled selected>Select Level</option>
                                    <option>Grade 7</option>
                                    <option>Grade 8</option>
                                    <option>Grade 9</option>
                                    <option>Grade 10</option>
                                    <option>Grade 11</option>
                                    <option>Grade 12</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Section *</label>
                                <input type="text" name="Section" placeholder="e.g. Rizal" required>
                            </div>
                            <div class="form-group">
                                <label>Emergency Contact *</label>
                                <input type="text" name="ParentContact" placeholder="09XX-XXX-XXXX" required>
                            </div>
                            <div class="form-group full-width">
                                <label>Address *</label>
                                <select name="Address" required>
                                    <option value="" disabled selected>Select Address</option>
                                    <option>NHA Kabac</option>
                                    <option>NHA Kampingganon</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Parents/Guardian Name *</label>
                                <input type="text" name="Parent" placeholder="Full Name" required>
                            </div>
                            <div class="form-group profile-upload-group full-width">
                                <label>Student Picture *</label>
                                <div class="photo-upload-container">
                                    <div class="photo-preview" id="imagePreview">
                                        <i class="fa-solid fa-user-astronaut" id="placeholderIcon"></i>
                                        <img src="" alt="Preview" id="previewImg" style="display:none;">
                                    </div>
                                    <div class="upload-controls">
                                        <input type="file" name="studentPhoto" id="studentPhoto" accept="image/*" hidden onchange="previewFile()">
                                        <button type="button" class="btn-browse" onclick="document.getElementById('studentPhoto').click()">
                                            <i class="fa-solid fa-camera"></i> Browse Photo
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="form-footer">
                            <button type="button" class="btn-secondary" onclick="closeModal()">Cancel</button>
                            <button type="submit" class="btn-primary-form">Register & Generate QR</button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- STUDENT LIST TABLE -->
            <div class="glass-card mt-4">
                <div class="section-heading-row">
                    <h2>List Of Students</h2>
                    <div class="search-wrapper">
                        <i class="fa-solid fa-magnifying-glass"></i>
                        <input type="text" placeholder="Search LRN or Name...">
                    </div>
                </div>

                <table class="modern-table">
                    <thead>
                        <tr>
                            <th>LRN</th>
                            <th>Full Name</th>
                            <th>Grade/Section</th>
                            <th>QR Code</th>
                            <th>Student Info</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var student in Model)
                        {
                            <tr>
                                <td><span class="id-tag">@student.LRN</span></td>
                                <td><strong>@student.FirstName @student.MiddleName @student.LastName</strong></td>
                                <td>@student.GradeLevel - @student.Section</td>
                                <td>
                                    <div>
                                        <!-- QR BUTTON -->
                                        <button type="button" class="icon-qr-trigger" onclick="viewQRCode('@student.QRCodeBase64')" title="View QR">
                                            <i class="fa-solid fa-qrcode"></i>
                                        </button>
                                    </div>
                                </td>
                                <td>
                                    <!-- INFO BUTTON -->
                                    <button type="button" class="btn-view-info"
                                            onclick="viewStudentInfo('@student.PhotoPath', '@student.FirstName @student.MiddleName @student.LastName', '@student.LRN', '@student.GradeLevel', '@student.Section', '@student.Address', '@student.Parent', '@student.ParentContact', '@student.StudentId')"
                                            title="Student Profile">
                                        <i class="fa-solid fa-circle-info"></i> View Student Info
                                    </button>
                                    </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- 2. QR VIEW MODAL -->
            <div class="modal-overlay" id="qrModalOverlay" onclick="closeQRView()">
                <div class="modal-content qr-view-box" onclick="event.stopPropagation()">
                    <button class="btn-close-modal" onclick="closeQRView()">&times;</button>
                    <h3>Student QR Identity</h3>
                    <div class="qr-container-full">
                        <img id="fullSizeQR" src="" alt="QR Code">
                    </div>
                    <p>Scan this code to verify boarding</p>
                </div>
            </div>

            <!-- 3. STUDENT FULL INFO MODAL (Two-Column Design) -->
            <div class="modal-overlay" id="studentInfoOverlay" onclick="closeInfoView()">
                <div class="modal-content profile-modal-box" onclick="event.stopPropagation()">
                    <button class="btn-close-modal" onclick="closeInfoView()">&times;</button>
                    <div class="profile-container">
                        <!-- LEFT SIDE: PICTURE -->
                        <div class="profile-sidebar">
                            <div class="profile-photo-frame">
                                <img id="info-photo" src="" alt="Student Profile">
                            </div>
                            <h3 id="info-name">Student Name</h3>
                            <span class="badge-role">Verified Student</span>
                        </div>
                        <!-- RIGHT SIDE: DATA -->
                        <div class="profile-details">
                            <h4><i class="fa-solid fa-user-graduate"></i> Student Information</h4>
                            <div class="info-grid">
                                <div class="info-item"><strong>LRN</strong> <span id="info-lrn"></span></div>
                                <div class="info-item"><strong>Student ID</strong> <span id="info-id"></span></div>
                                <div class="info-item"><strong>Grade Level</strong> <span id="info-grade"></span></div>
                                <div class="info-item"><strong>Section</strong> <span id="info-section"></span></div>
                                <div class="info-item"><strong>Home Address</strong> <span id="info-address"></span></div>
                                <div class="info-item"><strong>Guardian Name</strong> <span id="info-parent"></span></div>
                                <div class="info-item"><strong>Contact Number</strong> <span id="info-contact"></span></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </section>

        

        <!-- SECTION: REPORTS -->
        <section class="main-content" id="reports">




            <!-- QUICK INSIGHTS CARDS -->
            <div class="report-banner">
                <div class="report-text">
                    <h1>Transport Activity</h1>
                </div>

            </div>
            <div class="analytics-summary">
                <div class="insight-card">
                    <div class="insight-icon"><i class="fa-solid fa-calendar-check"></i></div>
                    <div class="insight-data">
                        <span class="label">Total Boardings</span>
                        <p>0</p>

                    </div>
                    <img src="~/students-removebg-preview.png">
                </div>
                <div class="section-header-reports">
                    <div class="report-view-toggle">
                        <button class="toggle-btn active" onclick="setReportView('daily')">Daily</button>
                        <button class="toggle-btn" onclick="setReportView('monthly')">Monthly</button>
                    </div>
                </div>
            </div>

            <!-- FILTER BAR -->
            <div class="report-filters glass-card">
                <div class="filter-controls" id="daily-filter">
                    <label><i class="fa-solid fa-calendar-day"></i> Select Date:</label>
                    <input type="date" class="modern-input">
                </div>
                <div class="filter-controls" id="monthly-filter" style="display:none;">
                    <label><i class="fa-solid fa-calendar-days"></i> Select Month:</label>
                    <input type="month" class="modern-input">
                </div>
                <button class="btn-generate">Generate Report <i class="fa-solid fa-arrow-right"></i></button>
            </div>

            <!-- THE REPORT TABLE -->
            <div class="glass-card report-results">
                <div class="results-header">
                    <h3>Boarding Logs</h3>
                    <button class="btn-export"><i class="fa-solid fa-file-pdf"></i> Export PDF</button>
                </div>
                <table class="modern-table">
                    <thead>
                        <tr>
                            <th>Student Name</th>
                            <th>LRN</th>
                            <th>Assigned Driver</th>
                            <th>Check-in Time</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><strong>Jose Rizal</strong></td>
                            <td><span class="lrn-tag">111222333</span></td>
                            <td>Dalisay</td>
                            <td>08:15 AM</td>

                        </tr>

                    </tbody>
                </table>
            </div>
        </section>

       

    </div>

    <script src="LguDashboard.js"></script>
    <script src="~/js/School.js" asp-append-version="true"></script>
</body>
</html>
