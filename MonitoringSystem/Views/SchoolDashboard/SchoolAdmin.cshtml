@{
    // THIS LINE TELLS THE PAGE WHICH NAVBAR TO USE
    Layout = "~/Views/Shared/SchoolLayout.cshtml";
}
@model MonitoringSystem.Models.SchoolAdminViewModel
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>STMS | LGU Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true">
    <style>

    </style>
</head>
<body>



    <div class="main-wrapper">

        <!-- SECTION: DASHBOARD HOME -->
        <section class="main-content" id="dashboard">
            <div class="hero-banner">
                <div class="hero-text">
                    <h1>Student Transport<br>Monitoring System</h1>

                </div>
                <div class="hero-visual">
                    <img src="~/freebus.jpg" alt="Bus Image">
                </div>
            </div>

            <div class="stats-grid">
                <div class="stat-card">
                    <div class="icon-box blue"><i class="fa-solid fa-users"></i></div>
                    <div class="info"><h3>Students</h3><p>0</p></div>
                    <img src="~/students-removebg-preview.png" class="bg-icon">
                </div>
            </div>
        </section>

        <!-- SECTION: STUDENTS -->

        <section class="main-content" id="students">
            <!-- BANNER -->
            <div class="report-banner">
                <div class="report-text"><h1>Students</h1></div>
            </div>

            <!-- STAT CARD -->
            <div class="analytics-summary">
                <div class="insight-card">
                    <div class="icon-box blue"><i class="fa-solid fa-users"></i></div>
                    <div class="insight-data">
                        <span class="label">Total Registered Students</span>
                        <p>@Model.Students.Count</p>
                    </div>
                    <img src="~/students-removebg-preview.png">
                </div>
            </div>

            <!-- REGISTRATION TRIGGER -->
            <div class="report-filters glass-card">
                <div class="filter-controls"><h1>Register New Student</h1></div>
                <button class="btn-generate" onclick="openModal()">
                    <i class="fa-solid fa-user-plus"></i> Add new Student
                </button>
            </div>

            <!-- 1. REGISTRATION MODAL -->
            <div class="modal-overlay" id="modalOverlay" onclick="closeModalOutside(event)">
                <div class="modal-content glass-card registration-section" onclick="event.stopPropagation()">
                    <button class="btn-close-modal" onclick="closeModal()">&times;</button>
                    <div class="card-header-gradient">
                        <i class="fa-solid fa-user-plus"></i>
                            <h2>New Student Registration</h2>
                            <p>Fill in details to generate profile and QR identity.</p>
                        
                    </div>

                    <form asp-action="RegisterStudent" asp-controller="SchoolDashboard" method="post" enctype="multipart/form-data" class="modern-form">
                        <div class="form-grid">
                            <div class="form-group full-width">
                                <label> LRN *</label>
                                <input type="text" name="LRN" placeholder="12-digit LRN" required>
                            </div>
                            <div class="form-group">
                                <label>Student Id</label>
                                <input type="text" name="StudentId" placeholder="Internal ID">
                            </div>
                            <div class="form-group">
                                <label>First Name *</label>
                                <input type="text" name="FirstName" placeholder="First Name" required>
                            </div>
                            <div class="form-group">
                                <label>Middle Name</label>
                                <input type="text" name="MiddleName" placeholder="Middle Name">
                            </div>
                            <div class="form-group">
                                <label>Last Name *</label>
                                <input type="text" name="LastName" placeholder="Last Name" required>
                            </div>
                            <div class="form-group">
                                <label>Grade Level *</label>
                                <select name="GradeLevel" required>
                                    <option value="" disabled selected>Select Level</option>
                                    <option>Grade 7</option>
                                    <option>Grade 8</option>
                                    <option>Grade 9</option>
                                    <option>Grade 10</option>
                                    <option>Grade 11</option>
                                    <option>Grade 12</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Section *</label>
                                <input type="text" name="Section" placeholder="e.g. Rizal" required>
                            </div>
                            <div class="form-group">
                                <label>Emergency Contact *</label>
                                <input type="text" name="ParentContact" placeholder="09XX-XXX-XXXX" required>
                            </div>
                            <div class="form-group full-width">
                                <label>Address *</label>
                                <select name="Address" required>
                                    <option value="" disabled selected>Select Address</option>
                                    <option>NHA Kabac</option>
                                    <option>NHA Kampingganon</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Parents/Guardian Name *</label>
                                <input type="text" name="Parent" placeholder="Full Name" required>
                            </div>
                            <div class="form-group profile-upload-group full-width">
                                <label>Student Picture *</label>
                                <div class="photo-upload-container">
                                    <div class="photo-preview" id="imagePreview">
                                        <i class="fa-solid fa-user-astronaut" id="placeholderIcon"></i>
                                        <img src="" alt="Preview" id="previewImg" style="display:none;">
                                    </div>
                                    <div class="upload-controls">
                                        <input type="file" name="studentPhoto" id="studentPhoto" accept="image/*" hidden onchange="previewFile()">
                                        <button type="button" class="btn-browse" onclick="document.getElementById('studentPhoto').click()">
                                            <i class="fa-solid fa-camera"></i> Browse Photo
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="form-footer">
                            <button type="button" class="btn-secondary" onclick="closeModal()">Cancel</button>
                            <button type="submit" class="btn-primary-form">Register & Generate QR</button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- STUDENT LIST TABLE -->
            <div class="glass-card mt-4">
                <div class="section-heading-row">
                    <h2>List Of Students</h2>
                    <div class="search-wrapper">
                        <i class="fa-solid fa-magnifying-glass"></i>
                        <input type="text" placeholder="Search LRN or Name...">
                    </div>
                </div>

                <table class="modern-table">
                    <thead>
                        <tr>
                            <th>LRN</th>
                            <th>Full Name</th>
                            <th>Grade/Section</th>
                            <th>QR Code</th>
                            <th>Student Info</th>
                            <th>Update Student</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var student in Model.Students)
                        {
                            <tr>
                                <td><span class="id-tag">@student.LRN</span></td>
                                <td><strong>@student.FirstName @student.MiddleName @student.LastName</strong></td>
                                <td>@student.GradeLevel - @student.Section</td>
                                <td>
                                    <div>
                                        <!-- QR BUTTON -->
                                        <button type="button" class="icon-qr-trigger" onclick="viewQRCode('@student.QRCodeBase64')" title="View QR">
                                            <i class="fa-solid fa-qrcode"></i>
                                        </button>
                                    </div>
                                </td>
                                <td>
                                    <button type="button" class="btn-view-info"
                                            onclick="viewSchStudentInfo('@Html.Raw(student.PhotoPath)', '@Html.Raw(student.FirstName) @Html.Raw(student.MiddleName) @Html.Raw(student.LastName)', '@student.LRN', '@student.GradeLevel', '@student.Section', '@Html.Raw(student.Address)', '@Html.Raw(student.Parent)', '@student.ParentContact', '@student.StudentId')">
                                        <i class="fa-solid fa-circle-info"></i> View Student Info
                                    </button>
                                </td>
                                <td>
                                    <button type="button" class="btn-view-info" style="background:#1e293b;"
                                            onclick="openUpdateModal('@student.StudentId', '@Html.Raw(student.FirstName)', '@Html.Raw(student.MiddleName)', '@Html.Raw(student.LastName)', '@student.GradeLevel', '@student.Section', '@student.ParentContact', '@student.Status')">
                                        <i class="fa-solid fa-pen-to-square"></i> Update
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- 2. QR VIEW MODAL -->
            <div class="modal-overlay" id="qrModalOverlay" onclick="closeQRView()">
                <div class="modal-content qr-view-box" onclick="event.stopPropagation()">
                    <button class="btn-close-modal" onclick="closeQRView()">&times;</button>
                    <h3>Student QR Identity</h3>
                    <div class="qr-container-full">
                        <img id="fullSizeQR" src="" alt="QR Code">
                    </div>
                    <p>Scan this code to verify boarding</p>
                </div>
            </div>

            <!-- 3. STUDENT FULL INFO MODAL (Two-Column Design) -->
            <div class="modal-overlay" id="schStudentInfoOverlay" onclick="closeSchInfoView()">
                <div class="modal-content profile-modal-box" onclick="event.stopPropagation()">
                    <button class="btn-close-modal" onclick="closeSchInfoView()">&times;</button>

                    <div class="modal-scroll-container">
                        <div class="profile-container">
                            <div class="profile-sidebar">
                                <div class="profile-photo-frame">
                                    <img id="sch-info-photo" src="" alt="Student Profile">
                                </div>
                                <h3 id="sch-info-name">Student Name</h3>
                                <span class="badge-role" style="background: #A3DE83; color: black; border:none; margin-top:10px;">Active</span>
                            </div>

                            <div class="profile-details">
                                <h4><i class="fa-solid fa-user-graduate"></i> Student Information</h4>
                                <div class="info-grid">
                                    <div class="info-item"><strong>LRN</strong> <span id="sch-info-lrn"></span></div>
                                    <div class="info-item"><strong>Student ID</strong> <span id="sch-info-id"></span></div>
                                    <div class="info-item"><strong>Grade Level</strong> <span id="sch-info-grade"></span></div>
                                    <div class="info-item"><strong>Section</strong> <span id="sch-info-section"></span></div>
                                    <div class="info-item full"><strong>Home Address</strong> <span id="sch-info-address"></span></div>
                                    <div class="info-item"><strong>Guardian Name</strong> <span id="sch-info-parent"></span></div>
                                    <div class="info-item"><strong>Contact Number</strong> <span id="sch-info-contact"></span></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!--  UPDATE STUDENT -->
            <div class="modal-overlay" id="updateStudentOverlay" onclick="closeUpdateModalOutside(event)">
                <div class="modal-content profile-modal-box" onclick="event.stopPropagation()" style="max-width: 800px !important;">

                    <button class="btn-close-modal" onclick="closeUpdateModal()">&times;</button>

                    <div class="profile-container">
                        <!-- LEFT SIDE: VISUAL IDENTITY -->
                        <div class="profile-sidebar" style="background: linear-gradient(180deg, #1e293b 0%, #0077b6 100%);">
                            <div class="profile-photo-frame" style="background: rgba(255,255,255,0.1); display:flex; align-items:center; justify-content:center; border: 4px solid rgba(255,255,255,0.2);">
                                <i class="fa-solid fa-user-pen" style="font-size: 60px; color: white;"></i>
                            </div>
                            <h3 style="color:white; margin:0;">Edit Profile</h3>
                            <span class="badge-role" style="background: #A3DE83; color: black; border:none; margin-top:10px;">Active</span>
                        </div>

                        <!-- RIGHT SIDE: EDIT FORM -->
                        <div class="profile-details">
                            <h4><i class="fa-solid fa-pen-to-square"></i> Edit Student Information</h4>

                            <form asp-action="UpdateStudent" asp-controller="SchoolDashboard" method="post" class="modern-form">
                                
                                <input type="hidden" name="StudentId" id="upd-id">

                                <div class="info-grid">
                                    <div class="info-item full">
                                        <strong>Student Status</strong>
                                        <select name="Status" id="upd-status" class="status-select" style="margin-top:5px; border: 2px solid #0077b6; font-weight:700;">
                                            <option value="Active">Active</option>
                                            <option value="Inactive">Inactive</option>
                                        </select>
                                    </div>

                                    <div class="info-item">
                                        <strong>First Name</strong>
                                        <input type="text" name="FirstName" id="upd-fname" required>
                                    </div>
                                    <div class="info-item">
                                        <strong>Middle Name</strong>
                                        <input type="text" name="MiddleName" id="upd-mname">
                                    </div>
                                    <div class="info-item">
                                        <strong>Last Name</strong>
                                        <input type="text" name="LastName" id="upd-lname" required>
                                    </div>
                                    <div class="info-item">
                                        <strong>Grade Level</strong>
                                        <select name="GradeLevel" id="upd-grade">
                                            <option>Grade 7</option>
                                            <option>Grade 8</option>
                                            <option>Grade 9</option>
                                            <option>Grade 10</option>
                                            <option>Grade 11</option>
                                            <option>Grade 12</option>
                                        </select>
                                    </div>
                                    <div class="info-item">
                                        <strong>Section</strong>
                                        <input type="text" name="Section" id="upd-section" required>
                                    </div>
                                    <div class="info-item">
                                        <strong>Emergency Contact</strong>
                                        <input type="text" name="ParentContact" id="upd-contact" required>
                                    </div>
                                </div>

                                <div class="form-footer" style="margin-top:20px; padding-top:15px;">
                                    <button type="button" class="btn-secondary" onclick="closeUpdateModal()">Cancel</button>
                                    <button type="submit" class="btn-primary-form" style="background:#1e293b;">Save Changes</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        

        <!-- SECTION: REPORTS (Transport Activity) -->
        <section class="main-content" id="reports">
            <div class="report-banner">
                <div class="report-text"><h1>Transport Activity</h1></div>
            </div>

            <div class="report-filters glass-card">
                <div id="rp-visual-badge" class="report-brand-box">
                    <img src="~/freebus.jpg" id="report-img" alt="Report Design">
                    
                </div>

                <div id="rp-filter-area" style="display: none; gap: 20px; align-items: center; flex: 1; justify-content: center;">
                    <div class="report-view-toggle">
                        <button class="toggle-btn active" onclick="rp_switchSubView('daily')">Daily</button>
                        <button class="toggle-btn" onclick="rp_switchSubView('monthly')">Monthly</button>
                    </div>
                    <div class="filter-controls" id="rp-daily-box">
                        <input type="date" class="modern-input">
                    </div>
                    <div class="filter-controls" id="rp-monthly-box" style="display:none;">
                        <input type="month" class="modern-input">
                    </div>
                </div>

                <button class="btn-generate" id="rp-toggle-btn" onclick="rp_handleMainToggle()">
                    View Transport Activity <i class="fa-solid fa-arrow-right"></i>
                </button>
            </div>

            <div class="glass-card report-results">
                <div class="results-header"><h3>Trip Overview</h3><button class="btn-export">Export PDF</button></div>
                <table class="modern-table">
                    <thead>
                        <tr>
                            <th>Trip ID</th>
                            <th>Date</th>
                            <th>Assigned Bus Aide</th>
                            <th>Total Boarded</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var trip in Model.TripLogs)
                        {
                            <tr>
                                <td><span class="id-tag">@trip.TripId</span></td>
                                <td>@trip.Date</td>
                                <td><strong>@trip.DriverName</strong></td>
                                <td>@trip.BoardedCount Students</td>
                                <td><span class="status success">Completed</span></td>
                                <td>
                                    <!-- ACTION BUTTON -->
                                    <button type="button" class="btn-view-info"
                                            onclick="viewTripDetails('@trip.TripId', '@trip.Date', '@trip.DriverName', '@trip.StartTime', '@trip.EndTime', '@trip.BoardedCount')">
                                        <i class="fa-solid fa-circle-info"></i> View Details
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <!-- TRIP DETAILS MODAL -->
            <div class="modal-overlay" id="tripDetailOverlay" onclick="closeTripView()">
                <div class="modal-content profile-modal-box" onclick="event.stopPropagation()" style="max-width: 900px !important;">
                    <button class="btn-close-modal" onclick="closeTripView()">&times;</button>

                    <div class="modal-scroll-container" style="max-height: 85vh; overflow-y: auto;">
                        <div class="profile-container">
                            <div class="profile-sidebar" style="background: linear-gradient(180deg, #102a43 0%, #0077b6 100%);">
                                <div class="profile-photo-frame" style="background: rgba(255,255,255,0.1); display:flex; align-items:center; justify-content:center; border:none;">
                                    <i class="fa-solid fa-bus-simple" style="font-size: 50px; color: white;"></i>
                                </div>
                                <h3 id="det-trip-id">TRP-000</h3>
                                <span class="badge-role" style="background: #2ecc71; color: white; border: none;">LOG COMPLETED</span>
                            </div>
                            <div class="profile-details">
                                <h4><i class="fa-solid fa-route"></i> Trip Data</h4>
                                <div class="info-grid">
                                    <div class="info-item"><strong>Date</strong> <span id="det-date"></span></div>
                                    <div class="info-item"><strong>Bus Aide</strong> <span id="det-driver"></span></div>
                                    <div class="info-item"><strong>Start</strong> <span id="det-start"></span></div>
                                    <div class="info-item"><strong>End</strong> <span id="det-end"></span></div>
                                </div>
                                <div class="trip-summary-pill" style="margin-top:20px; border:1px dashed #0077b6; padding:15px; border-radius:12px; display:flex; justify-content:space-between; align-items:center;">
                                    <span style="color:#94a3b8; font-size:13px; font-weight:700;">TOTAL BOARDED:</span>
                                    <strong id="det-count" style="font-size:24px; color:#0077b6;">0</strong>
                                </div>
                            </div>
                        </div>

                        <!-- Student LIST -->
                        <div class="manifest-section" style="padding: 30px 40px; background: #f8fafc; border-top: 1px solid #e2e8f0;">
                            <h4 style="color: #102a43; margin-bottom: 20px; font-size: 14px; text-transform: uppercase; font-weight: 800;">
                                <i class="fa-solid fa-clipboard-list" style="color:#0077b6;"></i> Students List
                            </h4>
                            <div class="glass-card" style="padding: 0; overflow: hidden; border-radius: 15px;">
                                <table class="modern-table mini" id="tripManifestTable">
                                    <thead><tr style="background:#f1f5f9;"><th>Name</th><th>Grade/Section</th><th>Address</th><th>Time</th><th>Status</th></tr></thead>
                                    <tbody><!-- Injected by JavaScript --></tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

       

    </div>

    <script src="LguDashboard.js"></script>
    <script src="~/js/School.js" asp-append-version="true"></script>
</body>
</html>
