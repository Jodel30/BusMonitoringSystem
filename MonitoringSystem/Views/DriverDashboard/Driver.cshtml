@{
    Layout = null;
}
@model MonitoringSystem.Models.DriverDashboardViewModel
<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Driver Dashboard</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="~/css/Driver.css" asp-append-version="true">
    <script src="~/js/html5-qrcode.min.js"></script>
</head>
<body>

    <div class="mobile-container">

        <div class="sidebar" id="sidebar">
            <h3>Driver Menu</h3>
            <ul>
                <li onclick="switchSection('scan')"><i class="fas fa-qrcode"></i> Dashboard</li>
                <li onclick="switchSection('active-trip')"><i class="fas fa-user"></i> Trip History</li>
                <li onclick="switchSection('register')"><i class="fas fa-search"></i> Manual Check-in</li>
                <li onclick="switchSection('onboard')"><i class="fas fa-users"></i> On-Board Students</li>
                <li style="color: #ff4d4d; margin-top: 50px;">
                    <a href="/Account/Login" title="Logout" style="color: #ff4d4d; margin-top: 50px; text-decoration: none;">
                        <i class="fas fa-sign-out-alt"></i> Logout
                  </a></li>
            </ul>
        </div>
        <div class="overlay-bg" id="overlay" onclick="toggleMenu()"></div>

        <div class="app-header">
            <i class="fas fa-bars fa-lg" onclick="toggleMenu()" style="cursor:pointer"></i>
            <h2 id="header-title">STMS</h2>
            <!-- THE TRIGGER: Profile Icon -->
            <div class="drv-user-trigger" onclick="drv_toggleProfile()">
                <i class="fas fa-user-circle fa-lg"></i>
            </div>

            <!-- THE DROPDOWN MODAL -->
            <div class="drv-profile-dropdown" id="drv_profileBox">
                <div class="drv-drop-header">
                    <div class="drv-avatar">
                        <i class="fa-solid fa-user-tie"></i>
                    </div>
                    <div class="drv-info">
                        <strong id="drv-name">Loading...</strong>
                        <span id="drv-role">Driver</span>
                    </div>
                </div>

                <div class="drv-drop-body">
                    <div class="drv-item">
                        <i class="fa-solid fa-id-badge"></i>
                        <div>
                            <small>Username</small>
                            <p id="drv-user">driver</p>
                        </div>
                    </div>
                    <div class="drv-item">
                        <i class="fa-solid fa-phone"></i>
                        <div>
                            <small>Contact</small>
                            <p id="drv-contact">N/A</p>
                        </div>
                    </div>
                </div>

                <div class="drv-drop-footer">
                    <a href="/Account/Login" class="btn-logout-pro">
                        <i class="fa-solid fa-right-from-bracket"></i> Log Out
                    </a>
                </div>
            </div>
        </div>
        
        <!-- SECTION 1: SCAN -->
        <div id="scan" class="content-section active">
            <div class="scan-container">
                <!-- HEADER HERO -->
                <div class="hero-banner" id="main-title">
                    <div class="hero-text">
                        <h1>Student Transport<br>Monitoring System</h1>

                    </div>
                    <div class="hero-visual">
                        <img src="~/freebus.jpg" alt="Bus Image">
                    </div>
                </div>

                
                <!-- STATE 1: TRIP SELECTION -->
                <div id="trip-idle-state" class="trip-action-container">
                    <button id="btn-start" class="btn-trip start" onclick="openStartTripModal()">
                        <i class="fa-solid fa-play"></i> Start Trip
                    </button>
                </div>

                <!-- STATE 2: SCANNER UI -->
                <div id="active-scanner-ui" style="display: none;">
                    <!-- LIVE COUNTER CARD -->
                    <div class="boarding-stats-card" onclick="switchSection('onboard')" style="cursor: pointer;">
                        <div class="stats-icon">
                            <i class="fa-solid fa-users"></i>
                        </div>
                        <div class="stats-info">
                            <span>Current On-Board</span>
                            <h2 id="active-live-count">0</h2>
                        </div>
                    </div>
                    <div style="text-align: center; margin-top: 20px;">
                        <span class="active-trip-badge">
                            ACTIVE: <strong id="active-trip-id-display">TRP-001</strong>
                        </span>
                    </div>

                    <div id="scanner-ui">
                        <p style="color: #102a43; font-weight: 600; text-align: center; margin-top: 20px;">
                            <span class="dot-pulse"></span> Scanner Active
                        </p>
                        <div id="reader" style="width: 100%; border-radius: 20px; overflow: hidden; margin-bottom: 20px; display: none;"></div>
                        <div class="qr-frame" id="static-frame"><i class="fas fa-qrcode"></i></div>
                        <button class="btn-main" id="start-btn" onclick="startScanner()">
                            <i class="fa-solid fa-camera"></i> Tap to Scan
                        </button>
                        <button class="btn-main" id="stop-btn" style="display:none; background: #e74c3c;" onclick="stopScanner()">
                            <i class="fa-solid fa-stop"></i> Stop Scanner
                        </button>
                    </div>

                    <button class="btn-end-trip" onclick="endTrip()" style="margin-top: 10px;">
                        <i class="fa-solid fa-route"></i> End Current Trip
                    </button>
                </div>

                <!-- STATE 3: SUCCESS MESSAGE -->
                <div id="scan-success" style="display:none; text-align:center; padding: 20px;">
                    <!-- SUCCESS COUNTER MINI-CARD -->
                    <div class="mini-count-success">
                        Total Boarded: <strong id="success-live-count">0</strong>
                    </div>

                    <div style="width: 130px; height: 130px; margin: 0 auto 15px; border-radius: 50%; overflow: hidden; border: 5px solid #2ecc71;">
                        <img id="scanned-photo" src="" style="width: 100%; height: 100%; object-fit: cover;">
                    </div>

                    <h2 id="scanned-name" style="color: #102a43; margin-bottom: 0px; font-size: 20px;">Student Name</h2>
                    <p id="scanned-id" style="color: #8898aa; margin-bottom: 0px;">ID: 00000</p>
                    <p id="scanned-address" style="color: #8898aa; margin-bottom: 0px;">Home Address</p>
                    <p id="scanned-level" style="color: #8898aa; margin-bottom: 5px;">Grade Level</p>

                    <div style="background: #dcfce7; color: #15803d; padding: 10px; border-radius: 10px; font-weight: 800; margin-bottom: 20px; font-size: 14px;">
                        <i class="fas fa-check-circle"></i> BOARDING RECORDED
                    </div>

                    <button class="btn-main" onclick="resetScanner()">Scan Next Student</button>
                </div>

            </div>
        </div>

        <div id="register" class="content-section">
            <div class="search-container">
                <input type="text" id="studentSearch" placeholder="Search Name or LRN..." onkeyup="filterStudents()">
            </div>
            <div id="studentList">
                @foreach (var student in Model.RegisteredStudents)
                {
                    <div class="student-item" data-name="@student.FirstName @student.LastName" data-lrn="@student.StudentLRN">
                        <div class="student-info">
                            <h4>@student.FirstName @student.LastName</h4>
                            <p>LRN: @student.StudentLRN | @student.GradeLevel</p>

                            <!-- NEW: REASON DROPDOWN -->
                            <select class="manual-reason-select" onchange="enableBoardButton(this)" style="margin-top: 10px; width: 100%; padding: 8px; border-radius: 8px; border: 1px solid #ddd; font-size: 12px;">
                                <option value="" disabled selected>-- Select Reason --</option>
                                <option value="Broken QR">QR Code Unavailable</option>
                                <option value="Forgot ID">Damaged QR Code</option>
                                <option value="Camera Issue">Camera Issue</option>
                            </select>
                        </div>

                        <!-- FIXED: Button starts with 'opacity: 0.5' and 'pointer-events: none' -->
                        <button class="btn-check"
                                id="btn-@student.StudentLRN"
                                style="opacity: 0.5; pointer-events: none;"
                                onclick="handleManualBoarding(this, '@student.StudentLRN', '@student.FirstName @student.LastName', '@student.GradeLevel', '@student.PhotoPath')">
                            Board Student
                        </button>
                    </div>
                }
            </div>
        </div>

        <div id="onboard" class="content-section">
            <h3 style="color: #102a43;">Currently On-Board</h3>
            <div id="onboardList">
                <p style="text-align:center; color:#8898aa; margin-top:50px;">No students scanned yet.</p>
            </div>
        </div>

        <!-- SECTION: Active trip -->
       

        <div id="active-trip" class="content-section">
            <div class="glass-card" style="padding: 20px; background: white; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05);">

                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                    <h3 style="color: #102a43; margin: 0; font-size: 18px;">
                        <i class="fa-solid fa-clock-history" style="color:#0077b6;"></i> Trip History
                    </h3>
                    <div style="text-align:right">
                        <span class="badge-role" style="background:#eef6fc; color:#0077b6; padding: 5px 12px; border-radius: 50px; font-size: 11px; font-weight: 700;">LOGS</span>
                    </div>
                </div>

                <div style="overflow-x: auto;">
                    <table class="history-table" id="tripLogTable">
                        <thead>
                            <tr>
                                <th>Trip ID</th>
                                <th>Date</th>
                                <th>Times</th>
                                <th style="text-align:center;">Boarded</th>
                            </tr>
                        </thead>
                        <tbody id="historyBody">
                            @if (Model != null && Model.TripHistory.Any())
                            {
                                @foreach (var log in Model.TripHistory)
                                {
                                    <tr>
                                        <td><span class="trip-id-tag">@log.TripID</span></td>
                                        <td>@log.Date</td>
                                        <td style="font-size:10px; color:#64748b;">
                                            In: @log.StartTime<br>Out: @log.EndTime
                                        </td>
                                        <td style="text-align:center;">
                                            <span class="count-pill">@log.TotalBoarded</span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <!-- Only shows if the database/list is empty -->
                                <tr id="no-data-row">
                                    <td colspan="4" style="text-align:center; color:#94a3b8; padding: 30px 0;">No trips recorded yet.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <!-- SYSTEM NOTIFICATION MODAL -->
        <div class="modal-overlay" id="systemAlertModal">
            <div class="modal-content system-alert-box">
                <div id="alert-icon-container">
                    <i class="fa-solid fa-circle-check" id="alert-icon"></i>
                </div>
                <h3 id="alert-title">System Alert</h3>
                <p id="alert-message">Message goes here.</p>

                <div class="alert-footer">
                    <button class="btn-alert-secondary" id="alert-btn-cancel" style="display:none;" onclick="closeSystemAlert()">Cancel</button>
                    <button class="btn-alert-primary" id="alert-btn-ok" onclick="closeSystemAlert()">Okay</button>
                </div>
            </div>
        </div>
        <!-- START TRIP CONFIRMATION MODAL -->
        <div class="modal-overlay" id="startTripModal">
            <div class="modal-content system-alert-box">
                <div id="alert-icon-container" class="alert-warning" style="background:#eef6fc; color:#0077b6;">
                    <i class="fa-solid fa-bus-simple"></i>
                </div>
                <h3>Begin Trip?</h3>
                <p>Are you ready to start the shift and begin scanning students?</p>

                <div class="alert-footer" style="display:flex; flex-direction:column; gap:10px;">
                    <!-- This button will trigger the actual handleStart -->
                    <button class="btn-alert-primary" onclick="confirmAndStart()">Yes, Start Now</button>
                    <button class="btn-alert-secondary" onclick="closeStartModal()">Cancel</button>
                </div>
            </div>
        </div>
    </div>
    

    <script src="~/js/Driver.js" asp-append-version="true"></script>
</body>
</html>
