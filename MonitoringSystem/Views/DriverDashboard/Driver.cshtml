@{
    Layout = null;
}
@model MonitoringSystem.Models.DriverDashboardViewModel
<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Driver Dashboard</title>
    <!-- IMPORTANT: Font Awesome Link for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="~/css/Driver.css" asp-append-version="true">
    <script src="~/js/html5-qrcode.min.js"></script>
</head>
<body>

    <div class="mobile-container">

        <div class="sidebar" id="sidebar">
            <h3>Driver Menu</h3>
            <ul>
                <li onclick="switchSection('scan')"><i class="fas fa-qrcode"></i> Dashboard</li>
                <li onclick="switchSection('active-trip')"><i class="fas fa-user"></i> Trip History</li>
                <li onclick="switchSection('register')"><i class="fas fa-search"></i> Manual Check-in</li>
                <li onclick="switchSection('onboard')"><i class="fas fa-users"></i> On-Board Students</li>
                <li style="color: #ff4d4d; margin-top: 50px;"><i class="fas fa-sign-out-alt"></i> Logout</li>
            </ul>
        </div>
        <div class="overlay-bg" id="overlay" onclick="toggleMenu()"></div>

        <div class="app-header">
            <i class="fas fa-bars fa-lg" onclick="toggleMenu()" style="cursor:pointer"></i>
            <h2 id="header-title">STMS</h2>
            <i class="fas fa-user"></i>
        </div>

        <!-- SECTION 1: SCAN -->
        <div id="scan" class="content-section active">
            <div class="scan-container">
                <!-- HEADER HERO -->
                <div class="hero-banner" id="main-title">
                    <div class="hero-text">
                        <h1>Student Transport<br>Monitoring System</h1>

                    </div>
                    <div class="hero-visual">
                        <img src="~/freebus.jpg" alt="Bus Image">
                    </div>
                </div>

                <!-- STATE 1: TRIP SELECTION (START SCREEN) -->
                <div id="trip-idle-state" class="trip-action-container">
                    <button id="btn-start" class="btn-trip start" onclick="handleStart()">
                        <i class="fa-solid fa-play"></i> Start Trip
                    </button>
                    
                </div>

                <!-- STATE 2: SCANNER UI -->
                <div id="active-scanner-ui" style="display: none;">
                    <!-- LIVE COUNTER CARD -->
                    <div class="boarding-stats-card" onclick="switchSection('onboard')" style="cursor: pointer;">
                        <div class="stats-icon">
                            <i class="fa-solid fa-users"></i>
                        </div>
                        <div class="stats-info">
                            <span>Current On-Board</span>
                            <h2 id="active-live-count">0</h2>
                        </div>
                    </div>

                    <div id="scanner-ui">
                        <p style="color: #102a43; font-weight: 600; text-align: center; margin-top: 20px;">
                            <span class="dot-pulse"></span> Scanner Active
                        </p>
                        <div id="reader" style="width: 100%; border-radius: 20px; overflow: hidden; margin-bottom: 20px; display: none;"></div>
                        <div class="qr-frame" id="static-frame"><i class="fas fa-qrcode"></i></div>
                        <button class="btn-main" id="start-btn" onclick="startScanner()">
                            <i class="fa-solid fa-camera"></i> Tap to Scan
                        </button>
                        <button class="btn-main" id="stop-btn" style="display:none; background: #e74c3c;" onclick="stopScanner()">
                            <i class="fa-solid fa-stop"></i> Stop Scanner
                        </button>
                    </div>

                    <button class="btn-end-trip" onclick="endTrip()" style="margin-top: 30px;">
                        <i class="fa-solid fa-route"></i> End Current Trip
                    </button>
                </div>

                <!-- STATE 3: SUCCESS MESSAGE -->
                <div id="scan-success" style="display:none; text-align:center; padding: 20px;">
                    <!-- SUCCESS COUNTER MINI-CARD -->
                    <div class="mini-count-success">
                        Total Boarded: <strong id="success-live-count">0</strong>
                    </div>

                    <div style="width: 130px; height: 130px; margin: 0 auto 15px; border-radius: 50%; overflow: hidden; border: 5px solid #2ecc71;">
                        <img id="scanned-photo" src="" style="width: 100%; height: 100%; object-fit: cover;">
                    </div>

                    <h2 id="scanned-name" style="color: #102a43; margin-bottom: 2px; font-size: 20px;">Student Name</h2>
                    <p id="scanned-id" style="color: #8898aa; margin-bottom: 15px;">ID: 00000</p>
                    <p id="scanned-address" style="color: #8898aa; margin-bottom: 15px;">Home Address</p>
                    <p id="scanned-level" style="color: #8898aa; margin-bottom: 15px;">Grade Level</p>

                    <div style="background: #dcfce7; color: #15803d; padding: 10px; border-radius: 10px; font-weight: 800; margin-bottom: 20px; font-size: 14px;">
                        <i class="fas fa-check-circle"></i> BOARDING VERIFIED
                    </div>

                    <button class="btn-main" onclick="resetScanner()">Scan Next Student</button>
                </div>

            </div>
        </div>

        <div id="register" class="content-section">
            <div class="search-container">
                <input type="text" id="studentSearch" placeholder="Search Name or LRN..." onkeyup="filterStudents()">
            </div>
            <div id="studentList">
                @foreach (var student in Model.RegisteredStudents)
                {
                    <div class="student-item" data-name="@student.FirstName @student.LastName" data-lrn="@student.LRN">
                        <div class="student-info">
                            <h4>@student.FirstName @student.LastName</h4>
                            <p>LRN: @student.LRN | @student.GradeLevel</p>
                        </div>
                        <!-- Call handleManualBoarding from your JS -->
                        <button class="btn-check" onclick="handleManualBoarding(this, '@student.LRN', '@student.FirstName @student.LastName', '@student.GradeLevel', '@student.PhotoPath')">
                            Board
                        </button>
                    </div>
                }
            </div>
        </div>


        <div id="onboard" class="content-section">
            <h3 style="color: #102a43;">Currently On-Board</h3>
            <div id="onboardList">
                <p style="text-align:center; color:#8898aa; margin-top:50px;">No students scanned yet.</p>
            </div>
        </div>

        <!-- SECTION: Active trip -->
       

        <div id="active-trip" class="content-section">
            <div class="glass-card" style="padding: 20px; background: white; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05);">

                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                    <h3 style="color: #102a43; margin: 0; font-size: 18px;">
                        <i class="fa-solid fa-clock-history" style="color:#0077b6;"></i> Trip History
                    </h3>
                    <div style="text-align:right">
                        <span class="badge-role" style="background:#eef6fc; color:#0077b6; padding: 5px 12px; border-radius: 50px; font-size: 11px; font-weight: 700;">LOGS</span>
                    </div>
                </div>

                <div style="overflow-x: auto;">
                    <table class="history-table" id="tripLogTable">
                        <thead>
                            <tr>
                                <th>Trip ID</th>
                                <th>Date</th>
                                <th>Times</th>
                                <th style="text-align:center;">Boarded</th>
                            </tr>
                        </thead>
                        <tbody id="historyBody">
                            @if (Model != null && Model.TripHistory.Any())
                            {
                                @foreach (var log in Model.TripHistory)
                                {
                                    <tr>
                                        <td><span class="trip-id-tag">@log.TripId</span></td>
                                        <td>@log.Date</td>
                                        <td style="font-size:10px; color:#64748b;">
                                            In: @log.StartTime<br>Out: @log.EndTime
                                        </td>
                                        <td style="text-align:center;">
                                            <span class="count-pill">@log.BoardedCount</span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <!-- Only shows if the database/list is empty -->
                                <tr id="no-data-row">
                                    <td colspan="4" style="text-align:center; color:#94a3b8; padding: 30px 0;">No trips recorded yet.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script src="~/js/Driver.js" asp-append-version="true"></script>
</body>
</html>
