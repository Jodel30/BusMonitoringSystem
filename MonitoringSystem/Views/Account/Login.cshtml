@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Login</title>

    <style>
        body {
            margin: 0;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            height: 100vh;
            display: flex;
            overflow: hidden;
        }

        .left {
            width: 50%;
            position: relative;
            display: flex;
            justify-content: flex-start; 
            align-items: center;
            color: white;
            background: url('/freebus.jpg') no-repeat center right;
            background-size: cover;
        }

          
            .left::before {
                content: "";
                position: absolute;
                inset: 0;
                background: linear-gradient(to right, rgba(33, 150, 203, 1) 0%, /* Solid Blue */
                rgba(33, 150, 203, 0.9) 30%, /* Start Fading */
                rgba(33, 150, 203, 0) 100% /* Transparent */
                );
                z-index: 1;
            }

        .left-content {
            position: relative;
            text-align: left;
            padding-left: 60px; /* Space from the left edge */
            z-index: 2;
            max-width: 80%;
        }

            .left-content h1 {
                font-size: 52px;
                font-weight: 700;
                line-height: 1.1;
                margin: 0;
                letter-spacing: -1px;
                text-shadow: 2px 2px 4px rgba(0,0,0,0.1);
            }

            .left-content p {
                font-size: 18px;
                margin-top: 20px;
                opacity: 0.9;
                font-weight: 400;
            }

      
        .right {
            width: 50%;
            background: #f4f7fa;
            display: flex;
            justify-content: center;
            align-items: center;
        }

      
        .login-box {
            width: 380px;
            padding: 40px;
            border-radius: 24px;
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(15px);
            box-shadow: 0 20px 50px rgba(0,0,0,0.1);
            text-align: center;
            border: 1px solid rgba(255,255,255,0.4);
        }

            .login-box h2 {
                margin-bottom: 30px;
                font-size: 28px;
                font-weight: 600;
                color: #333;
            }

            .login-box input {
                width: 100%;
                padding: 14px;
                margin-bottom: 20px;
                border-radius: 12px;
                border: 1px solid #ddd;
                outline: none;
                box-sizing: border-box;
                font-size: 15px;
            }

                .login-box input:focus {
                    border-color: #2196cb;
                    box-shadow: 0 0 8px rgba(33, 150, 203, 0.2);
                }

            .login-box button {
                width: 100%;
                padding: 14px;
                border: none;
                border-radius: 12px;
                background: #1a1a1a;
                color: white;
                font-size: 16px;
                font-weight: 600;
                cursor: pointer;
                transition: 0.3s;
            }

                .login-box button:hover {
                    background: #333;
                    transform: translateY(-2px);
                    box-shadow: 0 10px 20px rgba(0,0,0,0.15);
                }

        .error {
            color: #e74c3c;
            margin-top: 15px;
            font-size: 14px;
            font-weight: 500;
        }

    </style>
</head>

<body>

    <!-- LEFT SECTION -->
    <div class="left">
        <div class="left-content">
            <h1>Student Transport<br>Monitoring System</h1>
            <p>for LGU and School Administration</p>
        </div>
    </div>

    <!-- RIGHT SECTION -->
    <div class="right">
        <div class="login-box">
            <h2>Login</h2>

            <form asp-controller="Account" asp-action="Login" method="post">
                <input type="text" name="username" placeholder="Username" required />
                <input type="password" name="password" placeholder="Password" required />
                <button type="submit">Sign In</button>
            </form>

            @if (ViewBag.Error != null)
            {
                <div class="error">
                    @ViewBag.Error
                </div>
            }
        </div>
    </div>

</body>
</html>