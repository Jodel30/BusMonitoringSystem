@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Login</title>

    <style>
        body {
            margin: 0;
            font-family: 'Segoe UI', sans-serif;
            height: 100vh;
            display: flex;
        }

        /* LEFT SIDE */
        .left {
            width: 50%;
            background: #0077b6;
            color: white;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 40px;
        }

            .left h1 {
                font-size: 48px;
                margin-bottom: 10px;
            }

            .left h2 {
                font-size: 20px;
                font-weight: 500;
                margin-bottom: 10px;
            }

            .left p {
                font-size: 14px;
                opacity: 0.9;
            }

            .left img {
                width: 320px;
                margin-top: 30px;
                transition: transform 0.3s ease;
            }

                .left img:hover {
                    transform: scale(1.05);
                }

        /* RIGHT SIDE */
        .right {
            width: 50%;
            background: #f4f7fa;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .login-box {
            width: 350px;
            padding: 35px;
            border-radius: 20px;
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(10px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1);
            text-align: center;
        }

            .login-box h2 {
                margin-bottom: 25px;
                font-size: 24px;
            }

            .login-box input {
                width: 100%;
                padding: 12px;
                margin-bottom: 15px;
                border-radius: 10px;
                border: 1px solid #ccc;
                outline: none;
                transition: 0.3s;
            }

                .login-box input:focus {
                    border-color: #1677a5;
                    box-shadow: 0 0 5px rgba(22,119,165,0.3);
                }

            .login-box button {
                width: 100%;
                padding: 12px;
                border: none;
                border-radius: 10px;
                background: linear-gradient(135deg, #000000, #333333);
                color: white;
                font-size: 16px;
                cursor: pointer;
                transition: 0.3s;
            }

                .login-box button:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
                }

        .error {
            color: red;
            margin-top: 10px;
        }
    </style>
</head>

<body>

    <!-- LEFT -->
    <div class="left">
        <h1>WELCOME!</h1>
        <h2>Student Transport Monitoring System</h2>
        <p>for LGU and School Administration</p>

        <img src="~/lib/buslogo-removebg-preview.png" alt="Bus">
    </div>

    <!-- RIGHT -->
    <div class="right">
        <div class="login-box">
            <h2>Login</h2>

            <form method="post">
                <input type="text" name="username" placeholder="Enter Username" required />
                <input type="password" name="password" placeholder="Enter Password" required />

                <button type="submit">Login</button>
            </form>

            <div class="error">
                @ViewBag.Error
            </div>
        </div>
    </div>

</body>
</html>