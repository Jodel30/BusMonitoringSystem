@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Login - STMS</title>

    <style>
        body {
            margin: 0;
            font-family: 'Plus Jakarta Sans', 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            height: 100vh;
            display: flex;
            overflow: hidden;
        }

        .left {
            width: 50%;
            position: relative;
            display: flex;
            justify-content: flex-start;
            align-items: center;
            color: white;
            background: url('/freebus.jpg') no-repeat center right;
            background-size: cover;
        }

            .left::before {
                content: "";
                position: absolute;
                inset: 0;
                background: linear-gradient(to right, rgba(33, 150, 203, 1) 0%, rgba(33, 150, 203, 0.9) 30%, rgba(33, 150, 203, 0) 100% );
                z-index: 1;
            }

        .left-content {
            position: relative;
            text-align: left;
            padding-left: 60px;
            z-index: 2;
            max-width: 80%;
        }

            .left-content h1 {
                font-size: 52px;
                font-weight: 700;
                line-height: 1.1;
                margin: 0;
                letter-spacing: -1px;
                text-shadow: 2px 2px 4px rgba(0,0,0,0.1);
            }

            .left-content p {
                font-size: 18px;
                margin-top: 20px;
                opacity: 0.9;
                font-weight: 400;
            }

        .right {
            width: 50%;
            background: #f4f7fa;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .login-box {
            width: 380px;
            padding: 45px;
            border-radius: 24px;
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(15px);
            box-shadow: 0 20px 50px rgba(0,0,0,0.1);
            text-align: center;
            border: 1px solid rgba(255,255,255,0.4);
        }

            .login-box h2 {
                margin-bottom: 30px;
                font-size: 28px;
                font-weight: 600;
                color: #333;
            }

            .login-box input[type="text"],
            .login-box input[type="password"] {
                width: 100%;
                padding: 14px;
                margin-bottom: 15px;
                border-radius: 12px;
                border: 1px solid #ddd;
                outline: none;
                box-sizing: border-box;
                font-size: 15px;
                transition: 0.3s;
            }

            .login-box input:focus {
                border-color: #2196cb;
                box-shadow: 0 0 8px rgba(33, 150, 203, 0.2);
            }

        /* --- NEW REMEMBER ME STYLES --- */
        .remember-me-container {
            display: flex;
            align-items: center;
            justify-content: flex-start;
            margin-bottom: 25px;
            padding: 0 5px;
        }

            .remember-me-container input[type="checkbox"] {
                width: 18px;
                height: 18px;
                cursor: pointer;
                accent-color: #0077b6; /* Matches your brand blue */
            }

            .remember-me-container label {
                font-size: 14px;
                color: #64748b;
                cursor: pointer;
                margin-left: 10px;
                user-select: none;
                font-weight: 500;
            }
        /* ------------------------------ */

        .login-box button {
            width: 100%;
            padding: 15px;
            border: none;
            border-radius: 12px;
            background: #1a1a1a;
            color: white;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            transition: 0.3s;
        }

            .login-box button:hover {
                background: #333;
                transform: translateY(-2px);
                box-shadow: 0 10px 20px rgba(0,0,0,0.15);
            }

        .error {
            color: #e74c3c;
            margin-top: 15px;
            font-size: 14px;
            font-weight: 500;
        }

        .login-alert {
            display: flex;
            align-items: center;
            gap: 12px;
            background: #fff1f2; /* Light red/pink */
            border: 1px solid #fecaca;
            padding: 12px 15px;
            border-radius: 12px;
            color: #b91c1c; /* Deep professional red */
            font-size: 13px;
            font-weight: 600;
            margin-top: 20px;
            text-align: left;
            animation: shake 0.4s ease-in-out;
        }

            .login-alert i {
                font-size: 16px;
                color: #ef4444;
            }


        
    </style>
</head>

<body>

    <!-- LEFT SECTION -->
    <div class="left">
        <div class="left-content">
            <h1>Student Transport<br>Monitoring System</h1>
            <p>for LGU and School Administration</p>
        </div>
    </div>

    <!-- RIGHT SECTION -->
    <div class="right">
        <div class="login-box">
            <h2>Sign In</h2>

            <form asp-controller="Account" asp-action="Login" method="post">
                <input type="text" name="username" placeholder="Username" required />
                <input type="password" name="password" placeholder="Password" required />

                <!-- NEW REMEMBER ME CHECKBOX -->
                <div class="remember-me-container">
                    <input type="checkbox" name="rememberMe" id="rememberMe" value="true">
                    <label for="rememberMe">Remember me</label>
                </div>

                <button type="submit">Log In</button>
            </form>
            @if (ViewBag.Error != null)
            {
                <div class="login-alert">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <span>@ViewBag.Error</span>
                </div>
            }
        </div>
    </div>

</body>
</html>