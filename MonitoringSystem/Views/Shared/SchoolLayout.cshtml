@model MonitoringSystem.Models.SchoolAdminViewModel
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MonitoringSystem</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/_Layout.css" />
</head>
<body>

    <header class="top-nav">
        <div class="nav-container">
            <div class="brand">
                <img src="~/buslogo-removebg-preview.png" alt="logo">
                <span>STMS</span>
            </div>
            <nav>
                <ul>
                    <li><a href="#dashboard" class="active">Dashboard</a></li>
                    <li><a href="#students">Students</a></li>
                    <li><a href="#reports">Transport Activity</a></li>
                    <li><a href="#archive">Archive</a></li>
                </ul>
            </nav>
            <div class="notif-wrapper" onclick="toggleNotifModal()" style="position:relative; cursor:pointer;">
                <i class="fa-solid fa-bell" style="color:white; font-size:22px;"></i>

                @{
                    // 1. Count students needing Grade Level updates (1 year mark)
                    var reviewCount = Model.Students.Count(s => s.NeedsUpdate);

                    // 2. Count students needing QR replacements (5+ manual entries)
                    var qrCount = Model.Students.Count(s => s.NeedsNewQR);

                    // 3. Count students absent for 30+ days
                    var absenceCount = Model.Students.Count(s => s.IsLongAbsence);

                    // 4. Combine all for the total badge number
                    var totalAlerts = reviewCount + qrCount + absenceCount;
                }

                @if (totalAlerts > 0)
                {
                    <!-- The badge now shows the sum of all three types of alerts -->
                    <span class="notif-badge" style="position:absolute; top:-5px; right:-8px; background:#ef4444; color:white; font-size:10px; padding:2px 6px; border-radius:50px; border:2px solid #0077b6;">
                        @totalAlerts
                    </span>
                }
            </div>
            <div class="profile-area" style="position:relative;">
                <!-- THE ICON TRIGGER (Unique Function) -->
                <div onclick="lgu_toggleProfile()" style="cursor:pointer;" class="lgu-user-trigger">
                    <img class="profile-btn" src="~/logout-removebg-preview.png" alt="Profile">
                </div>

                <!-- THE DROPDOWN MODAL (Unique ID) -->
                <div class="user-dropdown-modal" id="lgu_profileBox">
                    <div class="user-dropdown-header">
                        <div class="u-drop-avatar"><i class="fa-solid fa-user-gear"></i></div>
                        <div class="u-drop-info">
                            <!-- Unique IDs for the text fields -->
                            <strong id="lgu-prof-name">Loading...</strong>
                            <span id="lgu-prof-role">ROLE</span>
                        </div>
                    </div>

                    <div class="user-dropdown-body">
                        <div class="u-drop-item">
                            <i class="fa-solid fa-at"></i>
                            <div>
                                <small>Username</small>
                                <p id="lgu-prof-user">username</p>
                            </div>
                        </div>
                        <div class="u-drop-item">
                            <i class="fa-solid fa-envelope"></i>
                            <div>
                                <small>Email Address</small>
                                <p id="lgu-prof-email">email@stms.gov.ph</p>
                            </div>
                        </div>
                    </div>

                    <div class="user-dropdown-footer">
                        <a href="/Account/Login" class="btn-logout-pro">
                            <i class="fa-solid fa-right-from-bracket"></i> Sign Out
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </header>
    <div class="container">
        @RenderBody()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

