@model MonitoringSystem.Models.SchoolAdminViewModel
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MonitoringSystem</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/_Layout.css" />
</head>
<body>

    <header class="top-nav">
        <div class="nav-container">
            <div class="brand">
                <img src="~/buslogo-removebg-preview.png" alt="logo">
                <span>STMS</span>
            </div>
            <nav>
                <ul>
                    <li><a href="#dashboard" class="active">Dashboard</a></li>
                    <li><a href="#students">Students</a></li>
                    <li><a href="#reports">Transport Activity</a></li>
                    <li><a href="#archive">Archive</a></li>
                </ul>
            </nav>
            <div class="notif-wrapper" onclick="toggleNotifModal()" style="position:relative; cursor:pointer;">
                <i class="fa-solid fa-bell" style="color:white; font-size:22px;"></i>

                @{
                    // Calculate alert count once to reuse
                    var alertCount = Model.Students.Count(s => s.NeedsUpdate);
                }

                @if (alertCount > 0)
                {
                    <!-- Only show badge if count > 0 -->
                    <span class="notif-badge" style="position:absolute; top:-5px; right:-8px; background:#ef4444; color:white; font-size:10px; padding:2px 6px; border-radius:50px; border:2px solid #0077b6;">
                        @alertCount
                    </span>
                }
            </div>
            <div class="profile-area">
                <a href="/Account/Login" title="Logout">
                    <img class="profile-btn" src="~/logout-removebg-preview.png" alt="Logout">
                </a>
            </div>
        </div>
    </header>
    <div class="container">
        @RenderBody()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

