

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>STMS | LGU Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true">
    <style>
       
    </style>
</head>
<body>

  

    <div class="main-wrapper">

        <!-- SECTION: DASHBOARD HOME -->
        <section class="main-content" id="dashboard">
            <div class="hero-banner">
                <div class="hero-text">
                    <h1>Student Transport<br>Monitoring System</h1>

                </div>
                <div class="hero-visual">
                    <img src="~/freebus.jpg" alt="Bus Image">
                </div>
            </div>

            <div class="stats-grid">
                <div class="stat-card">
                    <div class="icon-box blue"><i class="fa-solid fa-users"></i></div>
                    <div class="info"><h3>Students</h3><p>0</p></div>
                    <img src="~/students-removebg-preview.png" class="bg-icon">
                </div>
                <div class="stat-card">
                    <div class="icon-box cyan"><i class="fa-solid fa-bus"></i></div>
                    <div class="info"><h3>Total Buses</h3><p>0</p></div>
                    <img src="~/bus-removebg-preview.png" class="bg-icon">
                </div>
                <div class="stat-card">
                    <div class="icon-box navy"><i class="fa-solid fa-user-tie"></i></div>
                    <div class="info"><h3>Drivers</h3><p>0</p></div>
                    <img src="~/driver-removebg-preview.png" class="bg-icon">
                </div>
                <div class="stat-card">
                    <div class="icon-box grey"><i class="fa-solid fa-user-shield"></i></div>
                    <div class="info"><h3>Users</h3><p>0</p></div>
                    <img src="~/users-removebg-preview.png" class="bg-icon">
                </div>
            </div>
        </section>

        <!-- SECTION: STUDENTS -->
        <section class="main-content" id="students">
            <div class="report-banner">
                <div class="report-text">
                    <h1>Student Transport Logs</h1>
                </div>

            </div>
            <div class="analytics-summary">
                <div class="insight-card">
                    <div class="insight-icon"><i class="fa-solid fa-calendar-check"></i></div>
                    <div class="insight-data">
                        <span class="label">Total Boardings</span>
                        <p>0</p>

                    </div>
                    <img src="~/students-removebg-preview.png">
                </div>
                <div class="section-header-reports">
                    <div class="report-view-toggle">
                        <button class="toggle-btn active" onclick="setStudentView('daily')">Weekly</button>
                        <button class="toggle-btn" onclick="setStudentView('monthly')">Monthly</button>
                    </div>
                </div>
            </div>

            <!-- FILTER BAR -->
            <div class="report-filters glass-card">
                <div class="filter-controls" id="weekly-filter">
                    <label><i class="fa-solid fa-calendar-week"></i> Select Week:</label>
                    <input type="week" class="modern-input">
                </div>
                <div class="filter-controls" id="monthly-filter" style="display:none;">
                    <label><i class="fa-solid fa-calendar-days"></i> Select Month:</label>
                    <input type="month" class="modern-input">
                </div>
                <div class="filter-controls">
                    <label>Address *</label>
                    <select name="Address" required class="modern-input">
                        <option value="" disabled selected>Select Address</option>
                        <option>NHA Kabac</option>
                        <option>NHA Kampingganon</option>
                    </select>
                </div>
                <button class="btn-generate">
                    View Trip Summary <i class="fa-solid fa-arrow-right"></i>
                </button>
            </div>
            <div class="glass-card">
                <div class="section-heading">
                    <h2>List Of Students</h2>
                </div>
                <div class="search-wrapper">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input type="text" placeholder="Search LRN or Name...">
                </div>
                <table class="modern-table">
                    <thead>
                        <tr>
                            <th>LRN</th>
                            <th>Name</th>
                            <th>Level</th>
                            <th>Address</th>
                            <th>Contact</th>
                            <th>QR Code</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><span class="id-tag">123456789</span></td>
                            <td><strong>Jodel</strong></td>
                            <td>Grade 10</td>
                            <td>Kabac</td>
                            <td>0912-345-678</td>
                            <td><button class="icon-btn"><i class="fa-solid fa-qrcode"></i></button></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>

        <!-- SECTION: REPORTS -->
        <section class="main-content" id="reports">
            

            <!-- QUICK INSIGHTS CARDS -->
            <div class="report-banner">
                <div class="report-text">
                    <h1>Transport Activity</h1>
                </div>

            </div>
            <div class="analytics-summary">
                <div class="insight-card">
                    <div class="insight-icon"><i class="fa-solid fa-calendar-check"></i></div>
                    <div class="insight-data">
                        <span class="label">Total Boardings</span>
                        <p>0</p>
                        
                    </div>
                    <img src="~/students-removebg-preview.png" >
                </div>
                <div class="section-header-reports">
                    <div class="report-view-toggle">
                        <button class="toggle-btn active" onclick="setReportView('daily')">Daily</button>
                        <button class="toggle-btn" onclick="setReportView('monthly')">Monthly</button>
                    </div>
                </div>
            </div>

            <!-- FILTER BAR -->
            <div class="report-filters glass-card">
                <div class="filter-controls" id="daily-filter">
                    <label><i class="fa-solid fa-calendar-day"></i> Select Date:</label>
                    <input type="date" class="modern-input">
                </div>
                <div class="filter-controls" id="monthly-filter" style="display:none;">
                    <label><i class="fa-solid fa-calendar-days"></i> Select Month:</label>
                    <input type="month" class="modern-input">
                </div>
                <button class="btn-generate">Generate Report <i class="fa-solid fa-arrow-right"></i></button>
            </div>

            <!-- THE REPORT TABLE -->
            <div class="glass-card report-results">
                <div class="results-header">
                    <h3>Boarding Logs</h3>
                    <button class="btn-export"><i class="fa-solid fa-file-pdf"></i> Export PDF</button>
                </div>
                <table class="modern-table">
                    <thead>
                        <tr>
                            <th>Student Name</th>
                            <th>LRN</th>
                            <th>Assigned Driver</th>
                            <th>Check-in Time</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><strong>Jose Rizal</strong></td>
                            <td><span class="lrn-tag">111222333</span></td>
                            <td>Dalisay</td>
                            <td>08:15 AM</td>
                           
                        </tr>
                       
                    </tbody>
                </table>
            </div>
        </section>


        <!-- user section -->
        <section class="main-content" id="user">
            <div class="report-banner">
                <div class="report-text">
                    <h1>User Management</h1>
                </div>

            </div>
            <div class="analytics-summary">
                <div class="analytics-summary">
                    <div class="insight-card">
                        <div class="insight-icon"><i class="fa-solid fa-calendar-check"></i></div>
                        <div class="insight-data">
                            <span class="label">Total Users</span>
                            <p>0</p>

                        </div>
                        <img src="~/users-removebg-preview.png">
                    </div>
                </div>
            </div>

            <div class="report-filters glass-card">
                <div class="filter-controls" id="daily-filter">
                    <h1>System Accounts</h1>
                </div>
                <button class="btn-generate" onclick="openAccountModal()">
                    <i class="fa-solid fa-user-plus"></i> Create New Account
                </button>
            </div>

            <!-- ACCOUNT MODAL OVERLAY -->
            <div class="modal-overlay" id="accountModalOverlay" onclick="closeAccountModalOutside(event)">

                <div class="modal-content glass-card account-registration-box" onclick="event.stopPropagation()">

                    <button class="btn-close-modal" onclick="closeAccountModal()">&times;</button>

                    <div class="card-header">
                        <div class="header-icon-box">
                            <i class="fa-solid fa-id-card-clip"></i>
                        </div>
                        <div class="header-text">
                            <h2>Create System Account</h2>
                            <p>Register new personnel with specific access levels.</p>
                        </div>
                    </div>

                    <form class="modern-form">
                        <div class="form-grid">
                            <!-- COMMON FIELDS -->
                            <div class="form-group">
                                <label>First Name *</label>
                                <input type="text" placeholder="Enter First Name" required>
                            </div>
                            <div class="form-group">
                                <label>Last Name *</label>
                                <input type="text" placeholder="Enter Last Name" required>
                            </div>
                            <div class="form-group">
                                <label>Middle Name *</label>
                                <input type="text" placeholder="Enter Middle Name" required>
                            </div>
                            <div class="form-group">
                                <label>Username *</label>
                                <input type="text" placeholder="e.g. jodel_admin" required>
                            </div>

                            <div class="form-group full-width">
                                <label>Access Role *</label>
                                <select id="roleSelector" onchange="updateRoleFields()" required>
                                    <option value="" disabled selected>Choose Account Type</option>
                                    <option value="lgu">LGU Official</option>
                                    <option value="school">School Administrator</option>
                                    <option value="driver">Driver</option>
                                </select>
                            </div>

                            <!-- DYNAMIC SECTION: LGU -->
                            <div id="fields-lgu" class="role-specific-fields full-width" style="display:none;">
                                <div class="form-group">
                                    <label>Address</label>
                                    <input type="text" placeholder="Enter Address">
                                </div>
                                <div class="form-group">
                                    <label>Contact No.</label>
                                    <input type="text" placeholder="Enter Contact No.">
                                </div>
                            </div>

                            <!-- DYNAMIC SECTION: SCHOOL -->
                            <div id="fields-school" class="role-specific-fields full-width" style="display:none;">
                                <div class="form-grid">
                                    <div class="form-group">
                                        <label>Address</label>
                                        <input type="text" placeholder="Enter Address">
                                    </div>
                                    <div class="form-group">
                                        <label>Contact No.</label>
                                        <input type="text" placeholder="Enter Contact No.">
                                    </div>
                                    <div class="form-group">
                                        <label>Email Address</label>
                                        <input type="text" placeholder="e.g. example@gmail.com">
                                    </div>
                                    <div class="form-group">
                                        <label>School ID</label>
                                        <input type="text" placeholder="6-digit DepEd ID">
                                    </div>
                                </div>
                            </div>

                            <!-- DYNAMIC SECTION: DRIVER -->
                            <div id="fields-driver" class="role-specific-fields full-width" style="display:none;">
                                <div class="form-grid">
                                    <div class="form-group">
                                        <label>License Number</label>
                                        <input type="text" placeholder="XXX-XX-XXXXXX">
                                    </div>
                                    <div class="form-group">
                                        <label>Assigned Bus Number</label>
                                        <input type="text" placeholder="e.g. Bus-01">
                                    </div>
                                </div>
                            </div>

                            <!-- COMMON FIELDS -->
                            <div class="form-group full-width">
                                <label>Account Password *</label>
                                <input type="password" placeholder="••••••••" required>
                            </div>
                        </div>

                        <div class="form-footer">
                            <button type="reset" class="btn-secondary" onclick="closeModal()">Cancel</button>
                            <button type="submit" class="btn-primary-form">Create Account</button>
                        </div>
                    </form>
                </div>
            </div>

           
                
                <div class="glass-card account-list">
                    <div class="card-header-row">
                        <h3>Account List</h3>
                        <div class="search-mini">
                            <i class="fa-solid fa-search"></i>
                            <input type="text" placeholder="Search users...">
                        </div>
                    </div>
                    <div class="user-scroll-area">
                        
                        <div class="user-account-item">
                            <div class="u-avatar"><img class="profile-btn" src="~/logout-removebg-preview.png" alt="Logout"></div>
                            <div class="u-details">
                                <strong>LGU</strong>
                                
                            </div>
                            <span class="role-tag lgu">LGU</span>
                            <button class="btn-icon-sm"><i class="fa-solid fa-ellipsis-vertical"></i></button>
                        </div>
                      
                        <div class="user-account-item">
                            <div class="u-avatar school"><img class="profile-btn" src="~/logout-removebg-preview.png" alt="Logout"></div>
                            <div class="u-details">
                                <strong>Patao National High School</strong>
                                
                            </div>
                            <span class="role-tag school">School Admin</span>
                            <button class="btn-icon-sm"><i class="fa-solid fa-ellipsis-vertical"></i></button>
                        </div>
                        
                        <div class="user-account-item">
                            <div class="u-avatar driver"><img class="profile-btn" src="~/logout-removebg-preview.png" alt="Logout"></div>
                            <div class="u-details">
                                <strong>Ricardo Dalisay</strong>
                                
                            </div>
                            <span class="role-tag driver">Driver</span>
                            <button class="btn-icon-sm"><i class="fa-solid fa-ellipsis-vertical"></i></button>
                        </div>
                    </div>
                </div>
            

            <!-- PART 3: LOGIN AUDIT LOGS -->
            <div class="glass-card mt-4">
                <div class="card-header-icon">
                    <i class="fa-solid fa-clock-rotate-left"></i>
                    <h3>Activity Logs</h3>
                </div>
                <table class="modern-table">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Role</th>
                            <th>Action</th>
                            <th>Timestamp</th>
                            
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><strong>Admin Chief</strong></td>
                            <td><span class="role-tag lgu">LGU</span></td>
                            <td><span class="status success">Login Successful</span></td>
                            <td>Today, 08:30 AM</td>
                            
                        </tr>
                        <tr>
                            <td><strong>Ricardo Dalisay</strong></td>
                            <td><span class="role-tag driver">Driver</span></td>
                            <td><span class="status success">Login Successful</span></td>
                            <td>Today, 07:15 AM</td>
                            
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>

    </div>

    <script src="LguDashboard.js"></script>
</body>
</html>