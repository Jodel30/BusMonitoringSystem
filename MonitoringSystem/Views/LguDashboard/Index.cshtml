@model MonitoringSystem.Models.LguDashboardViewModel
@{
    // Update your counts at the top of the file
    var lowUsageCount = Model.Students.Count(s => s.IsLowUsage);
    var absenceAlertCount = Model.Students.Count(s => s.IsLongAbsence);
    // Add this to your totalAlerts variable for the bell badge
    var totalAlerts = lowUsageCount + absenceAlertCount;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>STMS | LGU Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true">
    <style>

    </style>
</head>
<body>



    <div class="main-wrapper">

        <!-- SECTION: DASHBOARD HOME -->
        <section class="main-content" id="dashboard">
            <div class="hero-banner">
                <div class="hero-text">
                    <h1>Student Transport<br>Monitoring System</h1>

                </div>
                <div class="hero-visual">
                    <img src="~/freebus.jpg" alt="Bus Image">
                </div>
            </div>

            <div class="stats-grid">
                <div class="stat-card">
                    <div class="icon-box blue"><i class="fa-solid fa-users"></i></div>
                    <div class="info"><h3>Students</h3><p>@Model.Students.Count</p></div>
                    <img src="~/students-removebg-preview.png" class="bg-icon">
                </div>
                <div class="stat-card" onclick="openLowUsageModal()" style="cursor: pointer; border-left: 5px solid #0891b2;">
                    <div class="icon-box cyan"><i class="fa-solid fa-chart-line"></i></div>
                    <div class="info">
                        <h3>Low Transport Usage</h3>
                        <p>@lowUsageCount</p>
                    </div>
                    <img src="~/bus-removebg-preview.png" class="bg-icon">
                </div>
                <div class="stat-card">
                    <div class="icon-box grey"><i class="fa-solid fa-user-shield"></i></div>
                    <div class="info"><h3>Users</h3><p>@Model.Accounts.Count</p></div>
                    <img src="~/users-removebg-preview.png" class="bg-icon">
                </div>
            </div>
        </section>

        <!-- SECTION: STUDENTS -->
        <section class="main-content" id="students">
            <div class="report-banner">
                <div class="report-text">
                    <h1>Student Transport Records</h1>
                </div>
            </div>

            <!-- FILTER BAR (Unique IDs for Students) -->
            <div class="report-filters glass-card">

                <!-- LEFT SIDE: BADGE -->
                <div id="stu-badge-wrapper" class="report-brand-box">
                    <div class="filter-controls"><h1>Student Transport Overview</h1></div>
                </div>

                <!-- CENTER: FILTERS -->
                <div id="stu-filter-area" style="display: none; gap: 20px; align-items: center; flex: 1; justify-content: center;">
                    <div class="filter-controls">
                        <label style="font-size: 14px; font-weight:700;"><i class="fa-solid fa-location-dot"></i> Address:</label>
                        <select id="stu-filter-address" class="modern-input">
                            
                            <option value="NHA Kabac">NHA Kabac</option>
                            <option value="NHA Kampingganon">NHA Kampingganon</option>
                            <option value="all">Others</option>
                        </select>

                        <label style="font-size: 14px; font-weight:700; margin-left:15px;">Grade:</label>
                        <select id="stu-filter-grade" class="modern-input">
                            <option value="all">All Grades</option>
                            <option>Grade 7</option>
                            <option>Grade 8</option>
                            <option>Grade 9</option>
                            <option>Grade 10</option>
                        </select>
                    </div>
                </div>

                <!-- RIGHT SIDE: TRIGGER BUTTON -->
                <button class="btn-generate" id="stu-toggle-btn" onclick="toggleStudentReports()">
                    View Trip Summary <i class="fa-solid fa-arrow-right"></i>
                </button>
            </div>
            <!-- STUDENT SYSTEM ALERT MODAL -->
            <div class="modal-overlay" id="stuAlertOverlay" onclick="stu_closeAlert()">
                <div class="modal-content system-alert-box" onclick="event.stopPropagation()">
                    <div style="width:60px; height:60px; background:#fee2e2; color:#ef4444; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 20px; font-size:24px;">
                        <i class="fa-solid fa-circle-exclamation"></i>
                    </div>
                    <h3 id="stu-alert-title" style="color:#102a43; margin-bottom:5px;">System Message</h3>
                    <p id="stu-alert-message" style="color:#64748b; font-size:14px; margin-bottom:20px;">Message here.</p>
                    <button class="btn-primary-form" onclick="stu_closeAlert()" style="width:100%;">Understood</button>
                </div>
            </div>
            <!-- DATA TABLE -->
            <div class="glass-card">
                <div class="section-heading">
                    <h2>List Of Students</h2>
                </div>

                <div class="search-mini" onclick="this.querySelector('input').focus();" style="cursor: text;">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input type="text" id="lguStudentSearch" placeholder="Search LRN or Name..." onkeyup="filterLguTable()">
                </div>
                <div class="activity-logs-scroll">
                <table class="modern-table" id="lguStudentTable">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>LRN</th>
                            <th>Grade & Section</th>
                            <th>Address</th>
                            <th style="text-align:center;">Boarding Logs</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Students != null && Model.Students.Any())
                        {
                            @foreach (var student in Model.Students)
                            {
                                <tr>
                                    <td><strong>@student.FirstName @student.MiddleName @student.LastName</strong></td>
                                    <td><span class="id-tag">@student.StudentLRN</span></td>
                                    <td>@student.GradeLevel - @student.Section</td>
                                    <td>@student.Address</td>
                                    <td style="text-align:center;">
                                        <button type="button" class="btn-view-info"
                                                    onclick="viewStudentInfo('@student.PhotoPath', '@student.FirstName @student.MiddleName @student.LastName', '@student.StudentLRN', '@student.GradeLevel', '@student.Section', '@student.Address', '@student.ParentGuardianName', '@student.ContactNum', '@student.StudentSchoolID')"
                                                title="Student Profile">
                                            <i class="fa-solid fa-circle-info"></i> View Trip Details
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" style="text-align:center; color:#94a3b8; padding: 40px;">
                                    <i class="fa-solid fa-user-slash" style="font-size: 24px; margin-bottom: 10px; display: block;"></i>
                                    No students registered yet.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                </div>
            </div>

            <!-- STUDENT FULL INFO MODAL -->
            <div class="modal-overlay" id="studentInfoOverlay" onclick="closeInfoView()">
                <div class="modal-content profile-modal-box" onclick="event.stopPropagation()">
                    <button class="btn-close-modal" onclick="closeInfoView()">&times;</button>

                    <div class="modal-scroll-container">
                        <div class="profile-container">
                            <div class="profile-sidebar">
                                <div class="profile-photo-frame">
                                    <img id="info-photo" src="" alt="Student Profile">
                                </div>
                                <h3 id="info-name">Student Name</h3>
                                <span class="badge-role">Verified Student</span>
                            </div>

                            <div class="profile-details">
                                <h4><i class="fa-solid fa-user-graduate"></i> Student Information</h4>
                                <div class="info-grid">
                                    <div class="info-item"><strong>LRN</strong> <span id="info-lrn"></span></div>
                                    <div class="info-item"><strong>Student ID</strong> <span id="info-id"></span></div>
                                    <div class="info-item"><strong>Grade Level</strong> <span id="info-grade"></span></div>
                                    <div class="info-item"><strong>Section</strong> <span id="info-section"></span></div>
                                    <div class="info-item full"><strong>Home Address</strong> <span id="info-address"></span></div>
                                    <div class="info-item"><strong>Guardian Name</strong> <span id="info-parent"></span></div>
                                    <div class="info-item"><strong>Contact Number</strong> <span id="info-contact"></span></div>
                                    <div class="trip-summary-pill">
                                        <span>Date Registered:</span>
                                        <strong id="info-reg-date">00/00/0000</strong>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="profile-history-section">
                            <div class="history-header">
                                <div class="header-main-info">
                                    <h4><i class="fa-solid fa-clock-rotate-left"></i> Boarding History</h4>

                                    <!-- STEP 1: SELECT MODE -->
                                    <div class="stu-history-filter">
                                        <button class="stu-filter-btn active" onclick="toggleStuInput('all', this)">All</button>
                                        <button class="stu-filter-btn" onclick="toggleStuInput('weekly', this)">Weekly</button>
                                        <button class="stu-filter-btn" onclick="toggleStuInput('monthly', this)">Monthly</button>
                                    </div>

                                    <!-- STEP 2: DYNAMIC INPUTS -->
                                    <div class="stu-input-area">
                                        <div id="stu-weekly-box" style="display:none;">
                                            <input type="week" id="stu-date-input" class="stu-modern-input" onchange="applyStuFilter('weekly')">
                                        </div>
                                        <div id="stu-monthly-box" style="display:none;">
                                            <input type="month" id="stu-month-input" class="stu-modern-input" onchange="applyStuFilter('monthly')">
                                        </div>
                                    </div>
                                </div>
                                <div style="display:flex; gap:10px;">
                                 
                                    <div class="trip-summary-pill">
                                        <span>Trips Taken:</span>
                                        <strong id="info-total-trips">0</strong>
                                    </div>

                                    
                                    <div class="trip-summary-pill">
                                        <span>Manual Entry:</span>
                                        <strong id="info-manual-scans" style="color: #d97706;">0</strong>
                                    </div>
                                </div>
                            </div>

                            <div class="history-table-wrapper">
                                <table class="modern-table mini">
                                    <thead>
                                        <tr>
                                            <th>Date</th>
                                            <th>Trip ID</th>
                                            <th>Time Scanned</th>
                                            <th>Entry Method</th>
                                        </tr>
                                    </thead>
                                    <tbody id="boarding-history-body">
                                        <!-- Rows injected here -->
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- SECTION: REPORTS (Transport Activity) -->
        <section class="main-content" id="reports">
            <div class="report-banner">
                <div class="report-text"><h1>Transport Activity</h1></div>
            </div>

            <div class="report-filters glass-card">
                <div id="rp-visual-badge" class="report-brand-box">
                <div class="filter-controls"><h1>Transport Activity Overview</h1></div>
                </div>

                <div id="rp-filter-area" style="display: none; gap: 20px; align-items: center; flex: 1; justify-content: center;">
                <div class="report-view-toggle">
                    <button class="toggle-btn active" onclick="lgu_switchReport('daily', this)">Daily</button>
                    <button class="toggle-btn" onclick="lgu_switchReport('monthly', this)">Monthly</button>
                </div>
                    <div class="filter-controls" id="rp-daily-box">
                    <input type="date" id="rp-date-input" class="modern-input">
                    </div>
                    <div class="filter-controls" id="rp-monthly-box" style="display:none;">
                    <input type="month" id="rp-month-input" class="modern-input">
                    </div>
                </div>

                <button class="btn-generate" id="rp-toggle-btn" onclick="rp_handleMainToggle()">
                    View Transport Activity <i class="fa-solid fa-arrow-right"></i>
                </button>
            </div>
        <!-- ADMIN SYSTEM ALERT MODAL -->
        <div class="modal-overlay" id="adminAlertOverlay" onclick="closeAdminAlert()">
            <div class="modal-content system-alert-box" onclick="event.stopPropagation()">
                <div id="admin-alert-icon-box" class="alert-icon-circle">
                    <i id="admin-alert-icon" class="fa-solid fa-circle-exclamation"></i>
                </div>
                <h3 id="admin-alert-title">System Message</h3>
                <p id="admin-alert-message">Please check your inputs.</p>

                <button class="btn-primary-form" onclick="closeAdminAlert()" style="width: 100%; margin-top: 10px;">
                    Understood
                </button>
            </div>
        </div>
        <div class="glass-card report-results">
            <div class="results-header">
                <h3>Daily Transport Activity</h3>
                <!-- TRIGGER BUTTON (Ensure it's OUTSIDE the ID below) -->
                <button type="button" class="btn-export" onclick="exportTransportReport()">
                    <i class="fa-solid fa-file-pdf"></i> Export PDF
                </button>
            </div>

            <!-- START OF PRINTABLE AREA (Add this ID) -->
            <div id="activity-report-pdf" style="background: white !important; padding: 20px; border-radius: 15px;">
                <div class="activity-logs-scroll">
                <table class="modern-table">
                    <thead>
                        <tr>
                            <th>Trip ID</th>
                            <th>Schedule</th>
                            <th>Date</th>
                            <th>Assigned Bus Aide</th>
                            <th>Total Boarded</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var trip in Model.TripLogs)
                        {
                            <tr>
                                <td><span class="id-tag">@trip.TripID</span></td>
                                <td>@trip.TripSchedule</td>
                                <td>@trip.Date</td>
                                <td><strong>@trip.DriverName</strong></td>
                                <td>@trip.TotalBoarded</td>
                                <td><span class="status success">Completed</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
                </div>
            </div>
            <!-- END OF PRINTABLE AREA -->
        </div>
            <!-- TRIP DETAILS MODAL -->
            <div class="modal-overlay" id="tripDetailOverlay" onclick="closeTripView()">
                <div class="modal-content profile-modal-box" onclick="event.stopPropagation()" style="max-width: 900px !important;">

                    <button class="btn-close-modal" onclick="closeTripView()">&times;</button>

                    
                    <div class="modal-scroll-container" style="max-height: 85vh; overflow-y: auto;">

                        <!-- TOP SECTION: TRIP INFO -->
                        <div class="profile-container">
                            <div class="profile-sidebar" style="background: linear-gradient(180deg, #102a43 0%, #0077b6 100%);">
                                <div class="profile-photo-frame" style="background: rgba(255,255,255,0.1); border: none; display: flex; align-items: center; justify-content: center;">
                                    <i class="fa-solid fa-bus-simple" style="font-size: 50px; color: white;"></i>
                                </div>
                                <h3 id="det-trip-id">TRP-000</h3>
                                <span class="badge-role" style="background: #2ecc71; color: white; border: none;">LOG COMPLETED</span>
                            </div>

                            <div class="profile-details">
                                <h4><i class="fa-solid fa-route"></i> Trip Operational Data</h4>
                                <div class="info-grid">
                                    <div class="info-item"><strong>Date of Trip</strong> <span id="det-date"></span></div>
                                    <div class="info-item"><strong>Assigned Bus Aide</strong> <span id="det-driver"></span></div>
                                    <div class="info-item"><strong>Departure Time</strong> <span id="det-start"></span></div>
                                    <div class="info-item"><strong>Arrival Time</strong> <span id="det-end"></span></div>
                                </div>
                                <div class="trip-summary-pill" style="margin-top:20px; border: 1px dashed #0077b6; padding: 15px; border-radius: 12px; display: flex; justify-content: space-between; align-items: center;">
                                    <span style="color:#94a3b8; font-size: 13px; font-weight:700;">TOTAL BOARDED:</span>
                                    <strong id="det-count" style="font-size: 24px; color:#0077b6;">0</strong>
                                </div>
                            </div>
                        </div>

                        <!-- student list -->
                        <div class="manifest-section" style="padding: 30px 40px; background: #f8fafc; border-top: 1px solid #e2e8f0;">
                            <h4 style="color: #102a43; margin-bottom: 20px; font-size: 14px; text-transform: uppercase; letter-spacing: 1px; font-weight: 800;">
                                <i class="fa-solid fa-clipboard-list" style="color: #0077b6;"></i> Student List
                            </h4>

                            <div class="glass-card" style="padding: 0; overflow: hidden; border-radius: 15px; border: 1px solid #e2e8f0;">
                                <table class="modern-table mini" id="tripManifestTable">
                                    <thead>
                                        <tr style="background: #f1f5f9;">
                                            <th style="padding: 15px;">Student Name</th>
                                            <th>Grade & Section</th>
                                            <th>Home Address</th>
                                            <th>Scanned At</th>
                                            <th style="text-align:center;">Entry Method</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <!-- JavaScript will inject rows here -->
                                    </tbody>
                                </table>
                            </div>
                        </div>

                    </div> 
                </div>
            </div>
        </section>


        <!-- user section -->
        <section class="main-content" id="user">
            <div class="report-banner">
                <div class="report-text">
                    <h1>User Management</h1>
                </div>

            </div>
            <div class="analytics-summary">
                <div class="analytics-summary">
                    <div class="insight-card">
                        <div class="insight-icon"><i class="fa-solid fa-calendar-check"></i></div>
                    <div class="insight-data">
                        <span class="label">Total Users</span>
                        <p>@Model.Accounts.Count</p>
                    </div>
                        <img src="~/users-removebg-preview.png">
                    </div>
                </div>
            </div>

            <div class="report-filters glass-card">
                <div class="report-text" id="daily-filter">
                    <h1>System Accounts</h1>
                </div>
                <button class="btn-generate" onclick="openAccountModal()">
                    <i class="fa-solid fa-user-plus"></i> Create New Account
                </button>
            </div>

            <!-- ACCOUNT MODAL OVERLAY -->
            <div class="modal-overlay" id="accountModalOverlay" onclick="closeAccountModalOutside(event)">

                <div class="modal-content glass-card account-registration-box" onclick="event.stopPropagation()">

                    <button class="btn-close-modal" onclick="closeAccountModal()">&times;</button>

                    <div class="card-header">
                        <div class="header-icon-box">
                            <i class="fa-solid fa-id-card-clip"></i>
                        </div>
                        <div class="header-text">
                            <h2>Create System Account</h2>
                            <p>Register new personnel with specific access levels.</p>
                        </div>
                    </div>

                <form asp-action="RegisterAccount" asp-controller="LguDashboard" method="post" class="modern-form">
                        <div class="form-grid">
                            <!-- COMMON FIELDS -->
                            <div class="form-group">
                                <label>First Name *</label>
                                <input type="text" placeholder="Enter First Name" name="FirstName" required>
                            </div>
                            <div class="form-group">
                                <label>Last Name *</label>
                            <input type="text" placeholder="Enter Last Name" name="LastName" required>
                            </div>
                            <div class="form-group">
                                <label>Middle Name *</label>
                                <input type="text" placeholder="Enter Middle Name" name="MiddleName" required>
                            </div>
                            <div class="form-group full-width">
                                <label>Access Role *</label>
                                <select id="roleSelector" name="Role" onchange="updateRoleFields()" required>
                                    <option value="" disabled selected>Choose Account Type</option>
                                    <option value="lgu">LGU School Bus Supervisor</option>
                                    <option value="school">School Aide</option>
                                    <option value="driver">Bus Aide</option>
                                </select>
                            </div>
                        <!-- DYNAMIC SECTION: SCHOOL -->
                        <div id="fields-school" class="role-specific-fields full-width" style="display:none;">
                            <div class="form-grid">

                                <div class="form-group">
                                    <label>Email Address</label>
                                    <input type="text" placeholder="e.g. example@gmail.com" name="Email" class="role-input">
                                </div>
                                <div class="form-group">
                                    <label>School ID</label>

                                    <input type="text" placeholder="6-digit DepEd ID" name="SchoolId" class="role-input">
                                </div>
                            </div>
                        </div>
                        <div class="form-group">
                            <label>Username *</label>
                            <input type="text" placeholder="e.g. jodel_admin" name="Username" required>
                        </div>
                            <div class="form-group full-width">
                                <label>Account Password *</label>
                                <input type="password" placeholder="••••••••" name="Password" required>
                            </div>

                        <div class="form-group">
                                    <label>Address</label>
                                    <input type="text" placeholder="Enter Address" name="Address" class="role-input">
                                </div>
                                <div class="form-group">
                                    <label>Contact No.</label>
                                    <input type="text" placeholder="Enter Contact No." name="ContactNum" class="role-input">
                                </div>
                       
                        </div>

                        <div class="form-footer">
                            <button type="reset" class="btn-secondary" onclick="closeModal()">Cancel</button>
                            <button type="submit" class="btn-primary-form">Create Account</button>
                        </div>
                    </form>
                </div>
            </div>



            <div class="glass-card account-list">
                <div class="card-header-row">
                    <h3>Account List</h3>
                <div class="search-mini" onclick="this.querySelector('input').focus();" style="cursor: text;">
                        <i class="fa-solid fa-search"></i>
                        <input type="text" placeholder="Search users...">
                    </div>
                </div>
            <div class="user-scroll-area">
                @if (Model.Accounts != null && Model.Accounts.Any())
                {
                    @foreach (var acc in Model.Accounts)
                    {
                        <div class="user-account-item" style="display:flex; justify-content:space-between; align-items:center;">
                            <!-- LEFT SIDE: User Info -->
                            <div style="display:flex; align-items:center; gap:15px;">
                                <div class="u-avatar">
                                    <img class="profile-btn" src="~/logout-removebg-preview.png">
                                </div>
                                <div class="u-details">
                                    <strong>@acc.FullName</strong>
                                    <p>@@@acc.Username</p>
                                </div>
                            </div>

                            <!-- RIGHT SIDE: Tags & Actions -->
                            <div style="display:flex; align-items:center; gap:12px;">
                                <!-- DYNAMIC ROLE TAGS -->
                                @if (acc.Role == "lgu")
                                {
                                    <span class="role-tag lgu">LGU Admin</span>
                                }
                                else if (acc.Role == "school")
                                {

                                    <span class="role-tag school">School Aide</span>
                                }
                                else
                                {

                                    <span class="role-tag driver">Bus Aide</span>
                                }

                                <!-- VIEW DETAILS BUTTON -->
                                <button type="button" class="btn-view-info"
                                        onclick="viewAccountDetails('@Html.Raw(acc.FirstName) @Html.Raw(acc.LastName)', '@acc.Username', '@acc.Role', '@Html.Raw(acc.Address)', '@acc.SchoolId', '@acc.ContactNum', '@acc.Email', '@acc.Password')">
                                    <i class="fa-solid fa-circle-info"></i> Info
                                </button>

                                <!-- UPDATE CREDENTIALS BUTTON -->
                                <button type="button" class="btn-view-info" style="background:#1e293b;"
                                        onclick="openAccountUpdateModal('@acc.Username', '@acc.Password')">
                                    <i class="fa-solid fa-key"></i> Update
                                </button>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p style="text-align:center; color:#94a3b8; padding:30px;">No custom accounts created yet.</p>
                }
            </div>

            <!-- SMALL MODAL FOR UPDATING USERNAME/PASSWORD -->
            <div class="modal-overlay" id="accountUpdateOverlay" onclick="closeAccountUpdateModal()">
                <div class="modal-content profile-modal-box" onclick="event.stopPropagation()" style="max-width: 400px !important;">
                    <button class="btn-close-modal" onclick="closeAccountUpdateModal()">&times;</button>

                    <div class="card-header-gradient" style="background: linear-gradient(135deg, #1e293b 0%, #0077b6 100%); padding:25px; text-align:center;">
                        <i class="fa-solid fa-shield-halved" style="font-size:30px; color:white; margin-bottom:10px;"></i>
                        <h2 style="color:white; margin:0; font-size:18px;">Update Credentials</h2>
                    </div>

                    <form asp-action="UpdateAccountCredentials" asp-controller="LguDashboard" method="post" class="modern-form" style="padding:25px;">
                        <!-- Hidden field to find the correct user in the C# List -->
                        <input type="hidden" name="OriginalUsername" id="upd-original-username">

                        <div class="form-group" style="margin-bottom:15px;">
                            <label>New Username</label>
                            <input type="text" name="NewUsername" id="upd-new-username" required>
                        </div>

                        <div class="form-group" style="margin-bottom:20px;">
                            <label>New Password</label>
                            <input type="password" name="NewPassword" placeholder="Enter new password" required>
                        </div>

                        <button type="submit" class="btn-primary-form" style="background:#1e293b; width:100%;">Save Changes</button>
                    </form>
                </div>
            </div>
            <!-- SYSTEM ACCOUNT INFO MODAL -->
            <div class="modal-overlay" id="accountInfoOverlay" onclick="closeAccountInfo()">
                <div class="modal-content profile-modal-box" onclick="event.stopPropagation()" style="max-width: 750px !important;">

                    <button class="btn-close-modal" onclick="closeAccountInfo()">&times;</button>

                    <div class="profile-container">
                        <!-- LEFT SIDE: ROLE & AVATAR -->
                        <div class="profile-sidebar" style="background: linear-gradient(180deg, #102a43 0%, #0077b6 100%);">
                            <div class="profile-photo-frame" style="background: rgba(255,255,255,0.1); border:none; display:flex; align-items:center; justify-content:center;">
                                <i class="fa-solid fa-user-gear" style="font-size: 50px; color: white;"></i>
                            </div>
                            <h3 id="acc-display-name">User Name</h3>
                            <span id="acc-display-role" class="badge-role" style="background:white; color:#0077b6; border:none; margin-top:10px;">Role</span>
                        </div>

                        <!-- RIGHT SIDE: FULL DETAILS -->
                        <div class="profile-details">
                            <h4><i class="fa-solid fa-id-card"></i> Account Credentials</h4>
                            <div class="info-grid">
                                <div class="info-item"><strong>Username</strong> <span id="acc-username"></span></div>
                                <div class="info-item"><strong>Password</strong> <span id="acc-password"></span></div>
                                <div class="info-item"><strong>Contact Number</strong> <span id="acc-contact"></span></div>
                                <div id="acc-email-container" class="info-item"><strong>Email Address</strong> <span id="acc-email"></span></div>
                            </div>
                                
                            <hr>

                            <!-- ROLE SPECIFIC DATA -->
                            <h4 id="role-section-title"><i class="fa-solid fa-briefcase"></i> Role Specific Information</h4>
                            <div class="info-grid">
                                <!-- This div will show Address for LGU/School -->
                                <div id="acc-address-container" class="info-item full">
                                    <strong>Registered Address</strong>
                                    <span id="acc-address"></span>
                                </div>

                                <!-- School ID -->
                                <div id="acc-school-id-container" class="info-item">
                                    <strong>School ID</strong>
                                    <span id="acc-school-id"></span>
                                </div>
                              
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            </div>


            <!-- PART 3: LOGIN AUDIT LOGS -->
            <div class="glass-card mt-4">
                <div class="card-header-icon">
                    <i class="fa-solid fa-clock-rotate-left"></i>
                    <h3>Activity Logs</h3>
                </div>
            <div class="activity-logs-scroll">
                <table class="modern-table">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Role</th>
                            <th>Action</th>
                            <th>Timestamp</th>

                        </tr>
                    </thead>
                <tbody>
                    @if (Model.ActivityLogs != null && Model.ActivityLogs.Any())
                    {
                        @foreach (var log in Model.ActivityLogs)
                        {
                            <tr>
                                <td><strong>@log.User</strong></td>
                                <td>
                                    @if (log.Role.ToLower() == "lgu")
                                    {
                                        <span class="role-tag lgu">LGU Supervisor</span>
                                    }
                                    else if (log.Role.ToLower() == "school")
                                    {
                                        <span class="role-tag school">School Aide</span>
                                    }
                                    else if (log.Role.ToLower() == "driver")
                                    {
                                        <span class="role-tag driver">Bus Aide</span>
                                    }
                                    else
                                    {
                                        <span class="role-tag">@log.Role</span>
                                    }
                                </td>
                                <td><span class="status success">@log.Action</span></td>
                                <td>@log.LogTime</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" style="text-align:center; color:#94a3b8; padding:20px;">No login activity recorded.</td>
                        </tr>
                    }
                </tbody>
                </table>
             </div>
            </div>

        <div class="notif-modal" id="notifModal">
            <div class="notif-header">
                <h3>Notifications</h3>
                <span class="close-notif" onclick="toggleNotifModal()">&times;</span>
            </div>
            <div class="notif-body">
                <!-- Notif 1: System Usage -->
                @if (lowUsageCount > 0)
                {
                    <div class="notif-item warning" onclick="openLowUsageModal(); toggleNotifModal();" style="border-left: 4px solid #0891b2;">
                        <div class="notif-icon" style="background:#ecfeff; color:#0891b2;"><i class="fa-solid fa-chart-line"></i></div>
                        <div class="notif-text">
                            <strong>Low Transport Usage</strong>
                            <p>@lowUsageCount students have 3 or fewer trips this week.</p>
                            <small>Efficiency Alert</small>
                        </div>
                    </div>
                }
                @if (absenceAlertCount > 0)
                {
                    <div class="notif-item info" onclick=" window.location.hash='#students' ; toggleNotifModal();" style="border-top: 1px solid #f1f5f9;">
                        <div class="notif-icon" style="background:#f1f5f9; color:#64748b;">
                            <i class="fa-solid fa-user-clock"></i>
                        </div>
                        <div class="notif-text">
                            <strong>Absence Review Required</strong>
                            <p>@absenceAlertCount students have not boarded in over 30 days.</p>
                            <small style="color:#64748b; font-weight:700;">Operational Review</small>
                        </div>
                    </div>
                }
                
                else
                {
                <!-- EMPTY STATE -->
                <div style="padding: 50px 20px; text-align: center; color: #94a3b8;">
                    <i class="fa-solid fa-circle-check" style="font-size: 40px; color: #2ecc71; margin-bottom: 15px; display: block;"></i>
                    <p>Everything is running smoothly. No alerts at this time.</p>
                </div>
                }
            </div>

            @if (totalAlerts > 0)
            {
                <div class="notif-footer">
                    <button class="btn-dismiss-all" onclick="toggleNotifModal()">Dismiss All</button>
                </div>
            }
        </div>

        <div class="modal-overlay" id="lowUsageModal" onclick="closeLowUsageModal()">
            <div class="modal-content glass-card" onclick="event.stopPropagation()" style="max-width: 800px !important;">
                <button class="btn-close-modal" onclick="closeLowUsageModal()">&times;</button>

                <div class="card-header-gradient" style="background: linear-gradient(135deg, #0891b2 0%, #102a43 100%); padding: 25px; color:white;">
                    <div style="display:flex; align-items:center; gap:15px;">
                        <i class="fa-solid fa-bus-circle-exclamation" style="font-size: 24px;"></i>
                        <div>
                            <h2 style="margin:0; font-size: 20px;">Low Transport Usage</h2>
                            <p style="margin:0; font-size: 12px; opacity: 0.8;">Students with 3 or fewer trips in the last 7 days.</p>
                        </div>
                    </div>
                </div>

                <div style="padding: 30px;">
                    <table class="modern-table">
                        <thead>
                            <tr>
                                <th>Student Name</th>
                                <th>LRN</th>
                                <th style="text-align:center;">Trips (7 Days)</th>
                                <th style="text-align:center;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var student in Model.Students.Where(s => s.IsLowUsage))
                            {
                                <tr>
                                    <td><strong>@student.FirstName @student.LastName</strong></td>
                                    <td><span class="id-tag">@student.StudentLRN</span></td>
                                    <td style="text-align:center;">
                                        <span class="status warning" style="background:#ecfeff; color:#0891b2; font-weight:800;">
                                            @student.WeeklyTripCount Trips
                                        </span>
                                    </td>
                                    <td style="text-align:center;">
                                        <button class="btn-view-info" style="background:#0891b2;" onclick="reviewLowUsage('@student.StudentLRN')">
                                            <i class="fa-solid fa-magnifying-glass"></i> Review Profile
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        </section>

    </div>
    <!-- jsPDF (The core PDF engine) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <!-- jsPDF-AutoTable (The table-building plugin) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.25/jspdf.plugin.autotable.min.js"></script>
    <script src="LguDashboard.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
</body>
</html>