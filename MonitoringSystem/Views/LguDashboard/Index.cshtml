

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>STMS | LGU Dashboard</title>
    <!-- Modern Google Fonts & Font Awesome -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css">
</head>
<body>

  

    <div class="main-wrapper">

        <!-- SECTION: DASHBOARD HOME -->
        <section class="main-content" id="dashboard">
            <div class="hero-banner">
                <div class="hero-text">
                    <h1>Student Transport<br>Monitoring System</h1>

                </div>
                <div class="hero-visual">
                    <img src="~/freebus.jpg" alt="Fleet">
                </div>
            </div>

            <div class="stats-grid">
                <div class="stat-card">
                    <div class="icon-box blue"><i class="fa-solid fa-users"></i></div>
                    <div class="info"><h3>Students</h3><p>1,240</p></div>
                    <img src="~/students-removebg-preview.png" class="bg-icon">
                </div>
                <div class="stat-card">
                    <div class="icon-box cyan"><i class="fa-solid fa-bus"></i></div>
                    <div class="info"><h3>Total Buses</h3><p>14</p></div>
                    <img src="~/bus-removebg-preview.png" class="bg-icon">
                </div>
                <div class="stat-card">
                    <div class="icon-box navy"><i class="fa-solid fa-steering-wheel"></i></div>
                    <div class="info"><h3>Drivers</h3><p>28</p></div>
                    <img src="~/driver-removebg-preview.png" class="bg-icon">
                </div>
                <div class="stat-card">
                    <div class="icon-box grey"><i class="fa-solid fa-user-shield"></i></div>
                    <div class="info"><h3>Users</h3><p>5</p></div>
                    <img src="~/users-removebg-preview.png" class="bg-icon">
                </div>
            </div>

            <div class="glass-card mt-5">
                <div class="card-header">
                    <h2>Recent Activity</h2>
                    <p>Live feed of student boarding events</p>
                </div>
                <table class="modern-table">
                    <thead>
                        <tr>
                            <th>Time Stamp</th>
                            <th>Total Boarded</th>
                            <th>Driver Assigned</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td>Today, 07:45 AM</td><td>45 Students</td><td>D-102 (Cardo)</td><td><span class="status success">Completed</span></td></tr>
                        <tr><td>Today, 08:30 AM</td><td>32 Students</td><td>D-105 (Juan)</td><td><span class="status warning">In Route</span></td></tr>
                    </tbody>
                </table>
            </div>
        </section>

        <!-- SECTION: STUDENTS -->
        <section class="main-content" id="students">
            <div class="section-heading">
                <h2><i class="fa-solid fa-user-graduate"></i> Student Registry</h2>
                <div class="header-tools">
                    
                    <button class="btn-action"><i class="fa-solid fa-plus"></i> Add Student</button>
                </div>
            </div>

            <div class="glass-card">
                <div class="search-wrapper">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input type="text" placeholder="Search LRN or Name...">
                </div>
                <table class="modern-table">
                    <thead>
                        <tr>
                            <th>LRN</th>
                            <th>Name</th>
                            <th>Level</th>
                            <th>Address</th>
                            <th>Contact</th>
                            <th>QR Code</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><span class="id-tag">123456789</span></td>
                            <td><strong>Jodel</strong></td>
                            <td>Grade 10</td>
                            <td>Kabac</td>
                            <td>0912-345-678</td>
                            <td><button class="icon-btn"><i class="fa-solid fa-qrcode"></i></button></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>

        <!-- SECTION: DRIVERS (Replaces Maintenance Location) -->
        <section class="main-content" id="driverlogs">
            <div class="section-heading">
                <h2><i class="fa-solid fa-id-card"></i> Driver Fleet Management</h2>
                <button class="btn-action"><i class="fa-solid fa-plus"></i> Register Driver</button>
            </div>

            <div class="driver-grid">
                <!-- Driver Card 1 -->
                <div class="driver-card glass-card">
                    <div class="driver-top">
                        <div class="online-indicator"></div>
                        <img src="~/driver-removebg-preview.png" alt="driver">
                    </div>
                    <h3>Ricardo Dalisay</h3>
                    <p class="driver-id">ID: DRV-001</p>
                    <div class="driver-details">
                        <span><i class="fa-solid fa-bus"></i> Bus A-01</span>
                        <span><i class="fa-solid fa-phone"></i> 0917-000-000</span>
                    </div>
                
                </div>
                <!-- Driver Card 2 -->
                <div class="driver-card glass-card">
                    <div class="driver-top">
                        <div class="online-indicator offline"></div>
                        <img src="~/driver-removebg-preview.png" alt="driver">
                    </div>
                    <h3>Juan Dela Cruz</h3>
                    <p class="driver-id">ID: DRV-002</p>
                    <div class="driver-details">
                        <span><i class="fa-solid fa-bus"></i> Bus B-05</span>
                        <span><i class="fa-solid fa-phone"></i> 0918-111-222</span>
                    </div>
                    
                </div>
            </div>
        </section>

        <!-- SECTION: REPORTS -->
        <section class="main-content" id="reports">
            <div class="section-heading">
                <h2><i class="fa-solid fa-file-invoice"></i> Reports & Analytics</h2>
                <div class="filter-group">
                    <input type="date" class="date-input">
                    <button class="btn-primary-sm">Filter</button>
                </div>
            </div>

            <div class="glass-card">
                <table class="modern-table">
                    <thead>
                        <tr><th>Student Name</th><th>LRN</th><th>Bus</th><th>Time Boarded</th></tr>
                    </thead>
                    <tbody>
                        <tr><td>Jose Rizal</td><td>111222333</td><td>Bus Line C</td><td>08:15 AM</td></tr>
                    </tbody>
                </table>
            </div>
        </section>

        <!-- SECTION: SECURITY / USER MANAGEMENT -->
        <section class="main-content" id="user">
            <h1>User Management</h1>
        </section>

    </div>

    <script src="LguDashboard.js"></script>
</body>
</html>